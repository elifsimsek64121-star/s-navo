        else
          ...List.generate(_hedefler.length, (i) {
            final h = _hedefler[i];
            return Container(margin: const EdgeInsets.only(bottom: 10),
              decoration: BoxDecoration(color: Theme.of(context).cardColor, borderRadius: BorderRadius.circular(16),
