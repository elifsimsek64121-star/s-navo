}

class _GoalUniversityScreenState extends State<GoalUniversityScreen> {
  List<HedefUniversite> _hedefler = [];
  final _adCtrl    = TextEditingController();
  final _bolumCtrl = TextEditingController();
  final _puanCtrl  = TextEditingController();

  @override
  void initState() { super.initState(); _load(); }

  Future<void> _load() async {
    final p = await PrefsCache.get();
    final raw = p.getStringList('hedef_universiteler') ?? [];
    final list = <HedefUniversite>[];
    for (final s in raw) {
      try { list.add(HedefUniversite.fromJson(jsonDecode(s))); } catch (_) {}
    }
    if (mounted) setState(() => _hedefler = list);
  }

  Future<void> _save() async {
    if (_adCtrl.text.isEmpty || _bolumCtrl.text.isEmpty || _puanCtrl.text.isEmpty) return;
    final h = HedefUniversite(ad: _adCtrl.text.trim(), bolum: _bolumCtrl.text.trim(), minPuan: _puanCtrl.text.trim());
    _hedefler.add(h);
    final p = await PrefsCache.get();
    await p.setStringList('hedef_universiteler', _hedefler.map((e) => jsonEncode(e.toJson())).toList());
    _adCtrl.clear(); _bolumCtrl.clear(); _puanCtrl.clear();
    if (mounted) setState(() {});
  }

  Future<void> _delete(int i) async {
    _hedefler.removeAt(i);
    final p = await PrefsCache.get();
    await p.setStringList('hedef_universiteler', _hedefler.map((e) => jsonEncode(e.toJson())).toList());
    if (mounted) setState(() {});
  }

  @override
  void dispose() { _adCtrl.dispose(); _bolumCtrl.dispose(); _puanCtrl.dispose(); super.dispose(); }

  @override
  Widget build(BuildContext context) {
    final isDark = Theme.of(context).brightness == Brightness.dark;
    return Scaffold(
      appBar: AppBar(
        title: Text('Hedef Üniversitelerim', style: GoogleFonts.poppins(fontWeight: FontWeight.bold)),
