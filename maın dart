  Map<String, dynamic> toJson() => {
    'id': id, 'examType': examType,
    'date': date.toIso8601String(),
    'nets': nets, 'score': score, 'notes': notes,
  };

  factory TryoutExam.fromJson(Map<String, dynamic> j) => TryoutExam(
    id: j['id'] ?? '',
    examType: j['examType'] ?? '',
    date: DateTime.tryParse(j['date'] ?? '') ?? DateTime.now(),
    nets: (j['nets'] as Map<String, dynamic>? ?? {}).map(
        (k, v) => MapEntry(k, (v is num) ? v.toDouble() : double.tryParse(v.toString()) ?? 0.0)),
    score: (j['score'] is num) ? (j['score'] as num).toDouble()
        : double.tryParse(j['score']?.toString() ?? '0') ?? 0.0,
    notes: j['notes'],
  );
}

