          FadeTransition(opacity: CurvedAnimation(parent: a, curve: Curves.easeIn), child: c),
        transitionDuration: const Duration(milliseconds: 250),
      ),
    );
  }

  @override
  void dispose() { _ctrl.dispose(); super.dispose(); }

