                decoration: const InputDecoration(labelText: 'Geçen Yıl Taban Puanı',
                  prefixIcon: Icon(Icons.bar_chart_rounded, color: kPrimary, size: 20))),
              const SizedBox(height: 14),
              SizedBox(width: double.infinity,
                child: ElevatedButton.icon(
                  onPressed: _save,
