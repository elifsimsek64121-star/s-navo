            TextField(controller: _puanCtrl, keyboardType: const TextInputType.numberWithOptions(decimal: true),
              decoration: const InputDecoration(labelText: 'Minimum Puan (geçen yıl)',
                prefixIcon: Icon(Icons.bar_chart_rounded, color: kPrimaryBlue))),
            const SizedBox(height: 14),
            SizedBox(width: double.infinity, child: ElevatedButton.icon(
              onPressed: _save, icon: const Icon(Icons.add), label: const Text('Hedef Ekle'))),
          ]))),
        const SizedBox(height: 16),
        if (_hedefler.isEmpty)
          const Center(child: Padding(padding: EdgeInsets.all(30),
            child: Column(children: [
              Icon(Icons.school_outlined, size: 56, color: Colors.grey),
              SizedBox(height: 12),
              Text('Henüz hedef eklemediniz.\nGeçen yıl taban puanlarını ekleyin\nve ilerlemenizi takip edin.',
