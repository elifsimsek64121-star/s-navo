class _AiCoachCard extends StatefulWidget {
  const _AiCoachCard();
  @override State<_AiCoachCard> createState() => _AiCoachCardState();
}

class _AiCoachCardState extends State<_AiCoachCard> {
  String _resp = '';
  bool _loading = false;
  http.Client? _client;

  @override
  void dispose() { _client?.close(); super.dispose(); }

  Future<void> _ask() async {
    if (!mounted) return;
    setState(() { _loading = true; _resp = ''; });

    final p = await PrefsCache.get();
    final hist = p.getStringList('history') ?? [];
    final streak = p.getInt('streak') ?? 0;
    final tryouts = p.getStringList('tryouts') ?? [];

    String ctx = '';
    if (hist.isNotEmpty) {
      try {
        final latest = jsonDecode(hist.first) as Map<String, dynamic>;
        ctx = 'Son hesaplama: ${latest['examTitle']} – ${latest['score']} puan. ';
      } catch (_) {}
    }

    // Net analizi
    if (tryouts.isNotEmpty) {
      try {
        final latest = TryoutExam.fromJson(jsonDecode(tryouts.first));
        if (latest.nets.isNotEmpty) {
          final weak = latest.nets.entries.reduce((a, b) => a.value < b.value ? a : b);
          ctx += 'En zayıf ders: ${weak.key} (${weak.value.toStringAsFixed(1)} net). ';
        }
      } catch (_) {}
    }

    try {
      _client = http.Client();

      // Önce backend proxy'yi dene
      if (kBackendProxyUrl != 'https://YOUR_BACKEND_URL/api/ai-coach') {
        await _callBackend(ctx, streak);
      } else if (kAnthropicKeyDev.isNotEmpty) {
        await _callAnthropicDirect(ctx, streak);
      } else {
        _fallback();
      }
    } catch (e) {
      debugPrint('AI request failed: $e');
      if (mounted) _fallback();
    } finally {
      _client?.close();
      _client = null;
      if (mounted) setState(() => _loading = false);
    }
  }

  Future<void> _callBackend(String ctx, int streak) async {
    final res = await _client!.post(
      Uri.parse(kBackendProxyUrl),
      headers: {'Content-Type': 'application/json'},
      body: jsonEncode({'context': ctx, 'streak': streak}),
    ).timeout(const Duration(seconds: 25));

    if (!mounted) return;
    if (res.statusCode == 200) {
      final data = jsonDecode(res.body) as Map<String, dynamic>;
      setState(() => _resp = data['text'] ?? '');
    } else {
      _fallback();
    }
  }

  Future<void> _callAnthropicDirect(String ctx, int streak) async {
    final res = await _client!.post(
      Uri.parse('https://api.anthropic.com/v1/messages'),
      headers: {
        'Content-Type': 'application/json',
        'x-api-key': kAnthropicKeyDev,
        'anthropic-version': '2023-06-01',
      },
      body: jsonEncode({
        'model': 'claude-sonnet-4-20250514',
        'max_tokens': 600,
        'messages': [{
          'role': 'user',
          'content': 'Sen bir Türk sınav koçusun. Öğrencinin durumu: $ctx '
            'Çalışma serisi: $streak gün. '
            'Bu öğrenciye 5 madde halinde kısa, motive edici, somut ve KİŞİSELLEŞTİRİLMİŞ çalışma önerileri ver. '
            'Emoji kullan, samimi ol, Türkçe yaz. '
            'Öğrencinin zayıf dersine özel strateji ver. '
            'Her madde farklı bir öğrenme stratejisi içersin.',
        }],
      }),
    ).timeout(const Duration(seconds: 25));

    if (!mounted) return;
    if (res.statusCode == 200) {
      final data = jsonDecode(res.body) as Map<String, dynamic>;
      final text = (data['content'] as List)
        .where((c) => c['type'] == 'text')
        .map((c) => c['text'] as String)
        .join('\n');
      if (mounted) setState(() => _resp = text);
    } else {
      debugPrint('AI error ${res.statusCode}: ${res.body}');
      _fallback();
    }
  }

  void _fallback() {
    if (!mounted) return;
    final tips = [
      '🎯 En zayıf dersine günde en az 2 saat ayır ve konu özetleri çıkar!',
      '📚 Pomodoro tekniği: 25 dk çalış, 5 dk mola. 4 turdan sonra 20 dk uzun mola!',
      '✍️ Yanlış yaptığın soruları özel bir deftere yaz ve her gün tekrar çöz!',
      '🔥 Çalışma serini koru! Her gün 1 konu bile olsa çalış – tutarlılık kazanır!',
      '📊 Deneme sonralarını analiz et: hangi konulardan hata yaptığını tespit et!',
    ];
    setState(() => _resp = tips.join('\n'));
  }

  @override
  Widget build(BuildContext context) => Container(
    padding: const EdgeInsets.all(18),
    decoration: BoxDecoration(
      gradient: const LinearGradient(colors: [Color(0xFF1A0535), Color(0xFF0D47A1)]),
      borderRadius: BorderRadius.circular(20),
      border: Border.all(color: kAccentOrange.withOpacity(0.3))),
    child: Column(crossAxisAlignment: CrossAxisAlignment.start, children: [
      Row(children: [
        Container(padding: const EdgeInsets.all(8),
          decoration: BoxDecoration(color: kAccentOrange.withOpacity(0.2), borderRadius: BorderRadius.circular(10)),
          child: const Icon(Icons.smart_toy_rounded, color: kAccentOrange)),
        const SizedBox(width: 12),
        const Expanded(child: Column(crossAxisAlignment: CrossAxisAlignment.start, children: [
          Text('AI Koç 🤖', style: TextStyle(color: Colors.white, fontWeight: FontWeight.bold, fontSize: 16)),
          Text('Yapay zeka destekli kişisel koçun', style: TextStyle(color: Colors.white54, fontSize: 12)),
        ])),
        Container(padding: const EdgeInsets.symmetric(horizontal: 8, vertical: 4),
          decoration: BoxDecoration(color: kSuccessGreen.withOpacity(0.2), borderRadius: BorderRadius.circular(8)),
          child: const Text('CANLI', style: TextStyle(color: kSuccessGreen, fontSize: 10, fontWeight: FontWeight.bold))),
      ]),
      if (_resp.isNotEmpty) ...[
        const SizedBox(height: 14),
        Container(padding: const EdgeInsets.all(14),
          decoration: BoxDecoration(color: Colors.white.withOpacity(0.07), borderRadius: BorderRadius.circular(12)),
          child: Text(_resp, style: const TextStyle(color: Colors.white70, fontSize: 14, height: 1.8))),
      ],
      if (_resp.isEmpty && !_loading)
        const Padding(padding: EdgeInsets.only(top: 10),
          child: Text('Verilerinizi analiz edip kişisel öneriler sunacağım!',
            style: TextStyle(color: Colors.white54, fontSize: 13))),
      const SizedBox(height: 14),
      SizedBox(width: double.infinity, child: ElevatedButton.icon(
        onPressed: _loading ? null : _ask,
        icon: _loading
          ? const SizedBox(width: 16, height: 16, child: CircularProgressIndicator(color: Colors.white, strokeWidth: 2))
          : const Icon(Icons.auto_awesome_rounded),
        label: Text(_loading ? 'AI düşünüyor...' : 'AI\'dan Kişisel Öneri Al',
          style: const TextStyle(fontWeight: FontWeight.bold)),
        style: ElevatedButton.styleFrom(backgroundColor: kAccentOrange, foregroundColor: Colors.white,
          padding: const EdgeInsets.symmetric(vertical: 14)),
      )),
    ]),
  );
