class TryoutScreen extends StatefulWidget {
  final bool isPremium;
  final Function(bool) onPremiumChange;
  final Function(int, {String? badgeId}) onXPAward;
  const TryoutScreen({super.key, required this.isPremium, required this.onPremiumChange, required this.onXPAward});
  @override State<TryoutScreen> createState() => _TryoutScreenState();
}

class _TryoutScreenState extends State<TryoutScreen> {
  List<TryoutExam> _tryouts = [];

  @override
  void initState() { super.initState(); _load(); }

  Future<void> _load() async {
    final p = await PrefsCache.get();
    final data = p.getStringList('tryouts') ?? [];
    final list = <TryoutExam>[];
    for (final s in data) {
      try { list.add(TryoutExam.fromJson(jsonDecode(s))); } catch (e) { debugPrint('Tryout parse: $e'); }
    }
    list.sort((a, b) => b.date.compareTo(a.date));
    if (mounted) setState(() => _tryouts = list);
  }

  Future<void> _save(TryoutExam t) async {
    final p = await PrefsCache.get();
    _tryouts.insert(0, t);
    await p.setStringList('tryouts', _tryouts.map((e) => jsonEncode(e.toJson())).toList());
    final ids = p.getStringList('earned_badges') ?? [];
    if (_tryouts.length >= 5 && !ids.contains('tryout_5')) widget.onXPAward(50, badgeId: 'tryout_5');
    if (_tryouts.length >= 20 && !ids.contains('tryout_20')) widget.onXPAward(150, badgeId: 'tryout_20');
    if (mounted) setState(() {});
  }

  Future<void> _delete(String id) async {
    final p = await PrefsCache.get();
    _tryouts.removeWhere((t) => t.id == id);
    await p.setStringList('tryouts', _tryouts.map((e) => jsonEncode(e.toJson())).toList());
    if (mounted) setState(() {});
  }

  void _showAdd() {
    if (!widget.isPremium && _tryouts.length >= 5) {
      Navigator.push(context, MaterialPageRoute(
        builder: (_) => PremiumPaywallScreen(onPremiumChange: widget.onPremiumChange)));
      return;
    }
    showModalBottomSheet(context: context, isScrollControlled: true, backgroundColor: Colors.transparent,
      builder: (_) => AddTryoutSheet(onSave: (t) async { await _save(t); widget.onXPAward(15); }));
  }

  @override
  Widget build(BuildContext context) {
    final isDark = Theme.of(context).brightness == Brightness.dark;
    return Scaffold(
      appBar: AppBar(
        title: Text('Denemelerim (${_tryouts.length})', style: GoogleFonts.poppins(fontWeight: FontWeight.bold)),
        automaticallyImplyLeading: false,
        backgroundColor: isDark ? kDarkCard : kPrimaryBlue, foregroundColor: Colors.white,
        actions: [IconButton(icon: const Icon(Icons.add_circle_rounded), onPressed: _showAdd)],
      ),
      floatingActionButton: _tryouts.isNotEmpty
        ? FloatingActionButton.extended(onPressed: _showAdd,
            icon: const Icon(Icons.add), label: const Text('Deneme Ekle'), backgroundColor: kPrimaryBlue)
        : null,
      body: _tryouts.isEmpty
        ? Center(child: Column(mainAxisAlignment: MainAxisAlignment.center, children: [
            const Icon(Icons.assignment_outlined, size: 72, color: Colors.grey),
            const SizedBox(height: 16),
            Text('Henüz deneme eklenmedi', style: GoogleFonts.poppins(fontSize: 18, color: Colors.grey)),
            const SizedBox(height: 8),
            Text('Her denemenizi kaydedin, gelişiminizi takip edin!', textAlign: TextAlign.center,
              style: GoogleFonts.poppins(fontSize: 13, color: Colors.grey.shade500)),
            const SizedBox(height: 20),
            ElevatedButton.icon(onPressed: _showAdd, icon: const Icon(Icons.add_rounded), label: const Text('İlk Denemeyi Ekle')),
          ]))
        : ListView.builder(
            padding: const EdgeInsets.all(16), itemCount: _tryouts.length,
            itemBuilder: (_, i) {
              final t = _tryouts[i];
              final s = t.score;
              final scoreColor = s >= 400 ? kSuccessGreen : s >= 250 ? Colors.orange : kErrorRed;
              return Dismissible(
                key: Key(t.id), direction: DismissDirection.endToStart,
                background: Container(alignment: Alignment.centerRight, padding: const EdgeInsets.only(right: 20),
                  decoration: BoxDecoration(color: kErrorRed, borderRadius: BorderRadius.circular(16)),
                  child: const Icon(Icons.delete_rounded, color: Colors.white)),
                confirmDismiss: (_) async => await showDialog<bool>(context: context, builder: (_) => AlertDialog(
                  title: const Text('Sil?'),
                  content: Text('${t.examType} denemesini silmek istiyor musunuz?'),
                  actions: [
                    TextButton(onPressed: () => Navigator.pop(context, false), child: const Text('İptal')),
                    TextButton(onPressed: () => Navigator.pop(context, true),
                      child: const Text('Sil', style: TextStyle(color: kErrorRed))),
                  ],
                )),
                onDismissed: (_) => _delete(t.id),
                child: Container(margin: const EdgeInsets.only(bottom: 12),
                  decoration: BoxDecoration(color: Theme.of(context).cardColor, borderRadius: BorderRadius.circular(18),
                    boxShadow: [BoxShadow(color: Colors.black.withOpacity(0.08), blurRadius: 8, offset: const Offset(0, 3))]),
                  child: ExpansionTile(
                    leading: Container(width: 50, height: 50,
                      decoration: BoxDecoration(color: scoreColor.withOpacity(0.15), borderRadius: BorderRadius.circular(12)),
                      child: Center(child: Text(t.score.toStringAsFixed(0),
                        style: TextStyle(color: scoreColor, fontWeight: FontWeight.bold, fontSize: 16)))),
                    title: Text(t.examType, style: const TextStyle(fontWeight: FontWeight.bold)),
                    subtitle: Text('${t.date.day}.${t.date.month}.${t.date.year}',
                      style: TextStyle(color: Colors.grey.shade500, fontSize: 12)),
                    trailing: Text(t.score.toStringAsFixed(2),
                      style: TextStyle(color: scoreColor, fontWeight: FontWeight.bold, fontSize: 18)),
                    children: [Padding(padding: const EdgeInsets.fromLTRB(16, 0, 16, 16),
                      child: Column(crossAxisAlignment: CrossAxisAlignment.start, children: [
                        if (t.nets.isNotEmpty) ...[
                          const Text('Ders Netleri:', style: TextStyle(fontWeight: FontWeight.bold, fontSize: 13)),
                          const SizedBox(height: 8),
                          Wrap(spacing: 8, runSpacing: 6, children: t.nets.entries.map((e) {
                            final n = e.value;
                            return Container(padding: const EdgeInsets.symmetric(horizontal: 10, vertical: 4),
                              decoration: BoxDecoration(
                                color: (n >= 0 ? kSuccessGreen : kErrorRed).withOpacity(0.12),
                                borderRadius: BorderRadius.circular(8),
                                border: Border.all(color: (n >= 0 ? kSuccessGreen : kErrorRed).withOpacity(0.3))),
                              child: Text('${e.key}: ${n.toStringAsFixed(1)}',
                                style: TextStyle(color: n >= 0 ? kSuccessGreen : kErrorRed,
                                  fontSize: 12, fontWeight: FontWeight.w600)));
                          }).toList()),
                        ],
                        if (t.notes != null && t.notes!.isNotEmpty) ...[
                          const SizedBox(height: 10),
                          Text('📝 ${t.notes}', style: const TextStyle(fontSize: 13, color: Colors.grey)),
                        ],
                      ]))],
                  ),
                ),
              );
            },
          ),
    );
  }
}

