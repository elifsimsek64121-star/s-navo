class StudyPlanScreen extends StatefulWidget {
  const StudyPlanScreen({super.key});
  @override State<StudyPlanScreen> createState() => _StudyPlanScreenState();
}

class _StudyPlanScreenState extends State<StudyPlanScreen> {
  String _exam = 'TYT';
  int _hours = 6;
  List<Map<String, dynamic>> _plan = [];

  static const _examTypes = ['TYT', 'AYT Sayısal', 'AYT EA', 'AYT Sözel', 'KPSS Lisans', 'LGS'];
  static const _subjects = {
    'TYT':         [{'sub': 'Türkçe', 'ratio': 0.30}, {'sub': 'Matematik', 'ratio': 0.30}, {'sub': 'Sosyal', 'ratio': 0.20}, {'sub': 'Fen', 'ratio': 0.20}],
    'AYT Sayısal': [{'sub': 'Matematik', 'ratio': 0.40}, {'sub': 'Fizik', 'ratio': 0.20}, {'sub': 'Kimya', 'ratio': 0.20}, {'sub': 'Biyoloji', 'ratio': 0.20}],
    'AYT EA':      [{'sub': 'Matematik', 'ratio': 0.35}, {'sub': 'Edebiyat', 'ratio': 0.30}, {'sub': 'Tarih', 'ratio': 0.20}, {'sub': 'Coğrafya', 'ratio': 0.15}],
    'AYT Sözel':   [{'sub': 'Edebiyat', 'ratio': 0.35}, {'sub': 'Tarih', 'ratio': 0.25}, {'sub': 'Coğrafya', 'ratio': 0.20}, {'sub': 'Felsefe', 'ratio': 0.20}],
    'KPSS Lisans': [{'sub': 'Türkçe', 'ratio': 0.25}, {'sub': 'Matematik', 'ratio': 0.25}, {'sub': 'Tarih', 'ratio': 0.25}, {'sub': 'Coğrafya', 'ratio': 0.25}],
    'LGS':         [{'sub': 'Türkçe', 'ratio': 0.30}, {'sub': 'Matematik', 'ratio': 0.30}, {'sub': 'Fen', 'ratio': 0.25}, {'sub': 'Sosyal', 'ratio': 0.15}],
  };

  void _generate() {
    final subs = _subjects[_exam] ?? [];
    final plan = <Map<String, dynamic>>[];
    for (var i = 0; i < 7; i++) {
      final day = {'day': _dayName(i), 'sessions': <Map<String, dynamic>>[]};
      if (i == 6) {
        (day['sessions'] as List).add({'subject': '📖 Tekrar & Test', 'minutes': _hours * 60});
      } else {
        for (final sub in subs) {
          final mins = (_hours * 60 * (sub['ratio'] as double)).round();
          (day['sessions'] as List).add({'subject': sub['sub'], 'minutes': mins});
        }
      }
      plan.add(day);
    }
    setState(() => _plan = plan);
  }

  String _dayName(int i) => ['Pazartesi', 'Salı', 'Çarşamba', 'Perşembe', 'Cuma', 'Cumartesi', 'Pazar'][i];

  @override
  Widget build(BuildContext context) {
    final isDark = Theme.of(context).brightness == Brightness.dark;
    return Scaffold(
      appBar: AppBar(title: Text('Çalışma Planı', style: GoogleFonts.poppins(fontWeight: FontWeight.bold)),
        backgroundColor: isDark ? kDarkCard : kPrimaryBlue, foregroundColor: Colors.white),
      body: SingleChildScrollView(padding: const EdgeInsets.all(16), child: Column(crossAxisAlignment: CrossAxisAlignment.start, children: [
        Card(shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(16)),
          child: Padding(padding: const EdgeInsets.all(16), child: Column(crossAxisAlignment: CrossAxisAlignment.start, children: [
            Text('Plan Oluştur', style: GoogleFonts.poppins(fontWeight: FontWeight.bold, fontSize: 17)),
            const SizedBox(height: 14),
            DropdownButtonFormField<String>(value: _exam,
              items: _examTypes.map((t) => DropdownMenuItem(value: t, child: Text(t))).toList(),
              onChanged: (v) => setState(() => _exam = v!),
              decoration: const InputDecoration(labelText: 'Hedef Sınav',
                prefixIcon: Icon(Icons.school_rounded, color: kPrimaryBlue))),
            const SizedBox(height: 12),
            Text('Günlük Çalışma Süresi: $_hours saat', style: const TextStyle(fontWeight: FontWeight.w600)),
            Slider(value: _hours.toDouble(), min: 2, max: 14, divisions: 12,
              label: '$_hours saat', activeColor: kPrimaryBlue,
              onChanged: (v) => setState(() => _hours = v.toInt())),
            const SizedBox(height: 8),
            SizedBox(width: double.infinity, child: ElevatedButton.icon(
              onPressed: _generate,
              icon: const Icon(Icons.calendar_month_rounded),
              label: const Text('Haftalık Plan Oluştur', style: TextStyle(fontWeight: FontWeight.bold, fontSize: 15)))),
          ]))),
        if (_plan.isNotEmpty) ...[
          const SizedBox(height: 16),
          Text('Haftalık Program', style: GoogleFonts.poppins(fontWeight: FontWeight.bold, fontSize: 17)),
          const SizedBox(height: 12),
          ..._plan.map((day) => Container(margin: const EdgeInsets.only(bottom: 12),
            decoration: BoxDecoration(color: Theme.of(context).cardColor, borderRadius: BorderRadius.circular(16),
              boxShadow: [BoxShadow(color: Colors.black.withOpacity(0.07), blurRadius: 8, offset: const Offset(0, 3))]),
            child: Column(crossAxisAlignment: CrossAxisAlignment.start, children: [
              Container(padding: const EdgeInsets.symmetric(horizontal: 16, vertical: 12),
                decoration: BoxDecoration(color: kPrimaryBlue.withOpacity(0.08),
                  borderRadius: const BorderRadius.vertical(top: Radius.circular(16))),
                child: Row(children: [
                  const Icon(Icons.calendar_today_rounded, color: kPrimaryBlue, size: 18),
                  const SizedBox(width: 8),
                  Text(day['day'] as String, style: const TextStyle(fontWeight: FontWeight.bold, fontSize: 15)),
                  const Spacer(),
                  Text('$_hours saat', style: const TextStyle(color: Colors.grey, fontSize: 13)),
                ])),
              Padding(padding: const EdgeInsets.all(12),
                child: Wrap(spacing: 8, runSpacing: 8,
                  children: (day['sessions'] as List<Map<String, dynamic>>).map((s) => Container(
                    padding: const EdgeInsets.symmetric(horizontal: 12, vertical: 8),
                    decoration: BoxDecoration(
                      color: kPrimaryBlue.withOpacity(0.1), borderRadius: BorderRadius.circular(10),
                      border: Border.all(color: kPrimaryBlue.withOpacity(0.2))),
                    child: Row(mainAxisSize: MainAxisSize.min, children: [
                      const Icon(Icons.book_rounded, color: kPrimaryBlue, size: 16),
                      const SizedBox(width: 6),
                      Text('${s['subject']}: ${s['minutes']} dk',
                        style: const TextStyle(fontWeight: FontWeight.w600, fontSize: 13)),
                    ]))).toList())),
            ]))),
        ],
      ])),
    );
  }
