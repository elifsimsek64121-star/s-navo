// AD MANAGER – Banner + Interstitial + Rewarded
// ─────────────────────────────────────────────────────────────
class AdManager {
  static InterstitialAd? _interstitial;
  static RewardedAd?     _rewarded;
  static bool _intLoaded    = false;
  static bool _rewardLoaded = false;
  static int  _clickCount   = 0;
  static bool _initialized  = false;

  static Future<void> preload() async {
    if (_initialized) return;
    _initialized = true;
    // Paralel yükleme, ana thread'i bloke etmez
    unawaited(_loadInterstitial());
    unawaited(_loadRewarded());
  }

  static Future<void> _loadInterstitial() async {
    try {
      final c = Completer<void>();
      InterstitialAd.load(
        adUnitId: kInterstitialAdId,
        request: const AdRequest(),
        adLoadCallback: InterstitialAdLoadCallback(
          onAdLoaded: (ad) { _interstitial = ad; _intLoaded = true; if (!c.isCompleted) c.complete(); },
          onAdFailedToLoad: (err) {
            _intLoaded = false;
            if (!c.isCompleted) c.complete();
            Future.delayed(const Duration(seconds: 90), _loadInterstitial);
          },
        ),
      );
      return c.future.timeout(const Duration(seconds: 15), onTimeout: () {});
    } catch (_) {}
  }

  static Future<void> _loadRewarded() async {
    try {
      final c = Completer<void>();
      RewardedAd.load(
        adUnitId: kRewardedAdUnitId,
        request: const AdRequest(),
        rewardedAdLoadCallback: RewardedAdLoadCallback(
          onAdLoaded: (ad) { _rewarded = ad; _rewardLoaded = true; if (!c.isCompleted) c.complete(); },
          onAdFailedToLoad: (err) {
            _rewardLoaded = false;
            if (!c.isCompleted) c.complete();
            Future.delayed(const Duration(seconds: 90), _loadRewarded);
          },
        ),
      );
      return c.future.timeout(const Duration(seconds: 15), onTimeout: () {});
    } catch (_) {}
  }

  static void tryShowInterstitial({int every = 6, VoidCallback? onDone}) {
    _clickCount++;
    if (_clickCount % every == 0 && _intLoaded && _interstitial != null) {
      _interstitial!.fullScreenContentCallback = FullScreenContentCallback(
        onAdDismissedFullScreenContent: (ad) {
          ad.dispose(); _interstitial = null; _intLoaded = false;
          unawaited(_loadInterstitial());
          onDone?.call();
        },
        onAdFailedToShowFullScreenContent: (ad, _) {
          ad.dispose(); _interstitial = null; _intLoaded = false;
          unawaited(_loadInterstitial());
          onDone?.call();
        },
      );
      _interstitial!.show();
    } else {
      onDone?.call();
    }
  }

  static void showRewarded({required VoidCallback onRewarded, VoidCallback? onNotAvailable}) {
    if (!_rewardLoaded || _rewarded == null) {
      onNotAvailable?.call();
      return;
    }
    _rewarded!.fullScreenContentCallback = FullScreenContentCallback(
      onAdDismissedFullScreenContent: (ad) {
        ad.dispose(); _rewarded = null; _rewardLoaded = false;
        unawaited(_loadRewarded());
      },
      onAdFailedToShowFullScreenContent: (ad, _) {
        ad.dispose(); _rewarded = null; _rewardLoaded = false;
        unawaited(_loadRewarded());
        onNotAvailable?.call();
      },
    );
    _rewarded!.show(onUserEarnedReward: (_, __) => onRewarded());
  }

  static void dispose() {
    _interstitial?.dispose();
    _rewarded?.dispose();
    _interstitial = null;
    _rewarded = null;
  }
}

