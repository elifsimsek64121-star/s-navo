    super.initState();
    _loadData();
    if (!widget.isPremium) _loadInterstitialAd();
    PremiumManager.initialize(widget.onPremiumChange);
    _countdowns = ExamDataProvider.getCountdowns();
  }

  Future<void> _loadData() async {
    final p = await PrefsCache.get();
    final now = DateTime.now();
    final today = '${now.year}-${now.month.toString().padLeft(2,'0')}-${now.day.toString().padLeft(2,'0')}';
    final lastStr = p.getString('last_open_date');
    int streak = p.getInt('streak') ?? 0;

    if (lastStr != null && lastStr.isNotEmpty && lastStr != today) {
      try {
        final last = DateTime.parse(lastStr);
        final diff = now.difference(last).inDays;
        if (diff == 1) streak++;
        else if (diff > 1) streak = 1;
      } catch (_) { streak = 1; }
    } else if (lastStr == null) {
      streak = 1;
    }

    if (lastStr != today) await p.setString('last_open_date', today);
    await p.setInt('streak', streak);

    int xp = p.getInt('xp_points') ?? 0;
    final earnedIds = p.getStringList('earned_badges') ?? [];

    bool changed = false;
    if (streak >= 3  && !earnedIds.contains('streak_3'))  { earnedIds.add('streak_3');  xp += 50;  changed = true; }
    if (streak >= 7  && !earnedIds.contains('streak_7'))  { earnedIds.add('streak_7');  xp += 100; changed = true; }
    if (streak >= 30 && !earnedIds.contains('streak_30')) { earnedIds.add('streak_30'); xp += 300; changed = true; }

    if (changed) {
      await p.setStringList('earned_badges', earnedIds);
      await p.setInt('xp_points', xp);
    }

    if (mounted) setState(() {
      _streak = streak; _xp = xp; _level = (xp ~/ 100) + 1;
      _favs = (p.getStringList('favorites') ?? []).toSet();
      _badges = _allBadges.where((b) => earnedIds.contains(b.id)).toList();
    });
  }

  Future<void> _awardXP(int amount, {String? badgeId}) async {
    final p = await PrefsCache.get();
    int xp = (p.getInt('xp_points') ?? 0) + amount;
    await p.setInt('xp_points', xp);
    if (badgeId != null) {
      final ids = p.getStringList('earned_badges') ?? [];
      if (!ids.contains(badgeId)) { ids.add(badgeId); await p.setStringList('earned_badges', ids); }
    }
    if (mounted) setState(() { _xp = xp; _level = (xp ~/ 100) + 1; });
  }

  Future<void> _toggleFav(String id) async {
    final p = await PrefsCache.get();
    final newFavs = _favs.toSet();
    newFavs.contains(id) ? newFavs.remove(id) : newFavs.add(id);
    await p.setStringList('favorites', newFavs.toList());
    if (mounted) setState(() => _favs = newFavs);
  }

  void _loadInterstitialAd() {
    InterstitialAd.load(
      adUnitId: kInterstitialAdId, request: const AdRequest(),
      adLoadCallback: InterstitialAdLoadCallback(
        onAdLoaded: (ad) { if (mounted) setState(() { _intAd = ad; _adLoaded = true; }); },
        onAdFailedToLoad: (_) {
          if (mounted) setState(() => _adLoaded = false);
          Future.delayed(const Duration(seconds: 30), () { if (mounted) _loadInterstitialAd(); });
        },
      ),
    );
  }

  void _navigateToExam(BuildContext ctx, String examId, String title) {
    if (!widget.isPremium) {
      _clicks++;
      if (_clicks % 8 == 0 && _adLoaded && _intAd != null) {
        _intAd!.fullScreenContentCallback = FullScreenContentCallback(
          onAdDismissedFullScreenContent: (ad) { ad.dispose(); _loadInterstitialAd(); _goToExam(ctx, examId, title); },
          onAdFailedToShowFullScreenContent: (ad, _) { ad.dispose(); _loadInterstitialAd(); _goToExam(ctx, examId, title); },
        );
        _intAd!.show();
        return;
      }
    }
    _goToExam(ctx, examId, title);
  }

  void _goToExam(BuildContext ctx, String examId, String title) {
    Navigator.of(ctx).push(PageRouteBuilder(
      pageBuilder: (_, __, ___) => ExamScreen(
        examId: examId, examTitle: title,
        isPremium: widget.isPremium, onXPAward: _awardXP,
      ),
      transitionsBuilder: (_, a, __, c) => SlideTransition(
        position: Tween(begin: const Offset(1, 0), end: Offset.zero)
          .animate(CurvedAnimation(parent: a, curve: Curves.easeOutCubic)), child: c),
      transitionDuration: const Duration(milliseconds: 300),
    ));
  }

