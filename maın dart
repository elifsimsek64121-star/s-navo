            const SizedBox(height: 12),
            TextField(controller: _adCtrl,
              decoration: const InputDecoration(labelText: 'Üniversite Adı',
                prefixIcon: Icon(Icons.account_balance_rounded, color: kPrimaryBlue))),
            const SizedBox(height: 10),
