  static String estimateRanking(String examId, double score) {
    if (examId.startsWith('yks')) {
      if (score >= 535) return '~İlk 1.000 🏆';
      if (score >= 515) return '~İlk 5.000 🥇';
      if (score >= 495) return '~İlk 10.000 🥈';
      if (score >= 475) return '~İlk 25.000 🥉';
      if (score >= 455) return '~İlk 50.000';
      if (score >= 435) return '~İlk 100.000';
      if (score >= 415) return '~İlk 200.000';
      if (score >= 385) return '~İlk 400.000';
      if (score >= 355) return '~İlk 600.000';
      if (score >= 315) return '~İlk 1.000.000';
      return '~1.000.000+';
    }
    if (examId == 'lgs') {
      if (score >= 490) return 'İlk %1 🏆';
      if (score >= 480) return 'İlk %5 🥇';
      if (score >= 460) return 'İlk %10 🥈';
      if (score >= 440) return 'İlk %25 🥉';
      if (score >= 400) return 'İlk %50';
      return 'Alt %50';
    }
    if (score >= 95) return 'İlk %2 🏆';
    if (score >= 90) return 'İlk %5 🥇';
    if (score >= 80) return 'İlk %15 🥈';
    if (score >= 70) return 'İlk %30 🥉';
    if (score >= 60) return 'İlk %50';
    return 'Alt %50';
  }

  static Map<String, int> getCountdowns() {
    final now = DateTime.now();
    final result = <String, int>{};
    final dates = {
      'YKS TYT': kYksTytTarihi,
      'YKS AYT': kYksAytTarihi,
      'KPSS':    kKpssTarihi,
      'LGS':     kLgsTarihi,
    };
    for (final e in dates.entries) {
      final target = DateTime.tryParse(e.value);
      if (target != null && target.isAfter(now)) {
        result[e.key] = target.difference(now).inDays + 1;
      }
    }
    return result;
  }
}

