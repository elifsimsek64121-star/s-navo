class ExamScreen extends StatefulWidget {
  final String examId, examTitle;
  final Function(int, {String? badgeId}) onXPAward;
  const ExamScreen({super.key, required this.examId, required this.examTitle, required this.onXPAward});
  @override State<ExamScreen> createState() => _ExamScreenState();
}

class _ExamScreenState extends State<ExamScreen> with SingleTickerProviderStateMixin {
  // Controller map'leri – late init güvenli
  final Map<String, TextEditingController> _c = {};
  final Map<String, TextEditingController> _w = {};
  final _obpCtrl   = TextEditingController();
  final _tytCtrl   = TextEditingController();
  final _hedefCtrl = TextEditingController();

  String _score = '0.00', _rawScore = '0.00', _obpScore = '0.00', _aytScore = '0.00';
  bool _busy = false;
  List<Map<String, dynamic>> _sections = [];
  final Map<String, double> _netMap = {};
  String _rank = '';

  late final AnimationController _resCtrl;
  late final Animation<double> _resScale;

  bool get _isYks => widget.examId.startsWith('yks');
  bool get _isLgs => widget.examId == 'lgs';

  @override
  void initState() {
    super.initState();
    _resCtrl = AnimationController(vsync: this, duration: const Duration(milliseconds: 500));
    _resScale = Tween(begin: 0.85, end: 1.0)
      .animate(CurvedAnimation(parent: _resCtrl, curve: Curves.elasticOut));

    final data = ExamDataProvider.getSections(widget.examId);
    _sections = List<Map<String, dynamic>>.from(data['all_sections'] as List);

    for (final s in _sections) {
      final t = s['title'] as String;
      _c[t] = TextEditingController();
      _w[t] = TextEditingController();
    }
  }

  @override
  void dispose() {
    // Tüm controller'ları güvenli dispose
    for (final c in _c.values) c.dispose();
    for (final c in _w.values) c.dispose();
    _obpCtrl.dispose();
    _tytCtrl.dispose();
    _hedefCtrl.dispose();
    _resCtrl.dispose();
    super.dispose();
  }

  double _getNet(String title) {
    final sec = _sections.firstWhere((s) => s['title'] == title, orElse: () => {});
    if (sec.isEmpty) return 0;
    final maxQ = sec['questions'] as int;
    final c = double.tryParse(_c[title]?.text ?? '') ?? 0;
    final w = double.tryParse(_w[title]?.text ?? '') ?? 0;
    if (c < 0 || w < 0 || (c + w) > maxQ) return double.nan;
    return c - (w / 4.0);
  }

  void _calculate() {
    if (_busy) return;
    if (_isYks) _calcYks();
    else if (_isLgs) _calcLgs();
    else _calcKpss();
  }

  void _calcYks() async {
    if (!mounted) return;
    setState(() { _busy = true; _netMap.clear(); });
    double tyt = 0, ayt = 0;
    bool err = false;

    for (final sec in _sections) {
      final title = sec['title'] as String;
      final tK = (sec['tyt_katsayi'] as num).toDouble();
      final aK = (sec['ayt_katsayi'] as num).toDouble();
      final net = _getNet(title);
      if (net.isNaN) { err = true; continue; }
      _netMap[title] = net;
      if (tK > 0) tyt += net * tK;
      if (aK > 0 && widget.examId != 'yks_tyt') ayt += net * aK;
    }

    if (err) {
      _showError('Doğru + Yanlış toplam soru sayısını aşamaz!');
      if (mounted) setState(() => _busy = false);
      return;
    }

    final userTyt = double.tryParse(_tytCtrl.text) ?? 0;
    final tytP = (userTyt > 0 && widget.examId != 'yks_tyt') ? userTyt : 100.0 + tyt;
    final obpRaw = double.tryParse(_obpCtrl.text) ?? 0;
    final obp = (obpRaw * 0.6).clamp(30.0, 60.0);
    final finalScore = (tytP + ayt + obp).clamp(100.0, 560.0);

    if (!mounted) return;
    setState(() {
      _rawScore = (tytP + ayt).toStringAsFixed(2);
      _obpScore = obp.toStringAsFixed(2);
      _aytScore = ayt.toStringAsFixed(2);
      _score = finalScore.toStringAsFixed(2);
      _rank = ExamDataProvider.estimateRanking(widget.examId, finalScore);
      _busy = false;
    });
    _resCtrl.forward(from: 0);
    await _saveHistory();
    await _checkBadges(finalScore);
    _showMotivation();
  }

  void _calcLgs() async {
    if (!mounted) return;
    setState(() { _busy = true; _netMap.clear(); });
    double wNet = 0, wTotal = 0;
    bool err = false;

    for (final sec in _sections) {
      final title = sec['title'] as String;
      final weight = (sec['weight'] as num).toDouble();
      final maxQ = sec['questions'] as int;
      final net = _getNet(title);
      if (net.isNaN) { err = true; continue; }
      _netMap[title] = net;
      wNet += net * weight;
      wTotal += maxQ * weight;
    }

    if (err) {
      _showError('Soru sınırını aştınız!');
      if (mounted) setState(() => _busy = false);
      return;
    }

    final lgs = wTotal > 0
      ? (100.0 + (wNet / wTotal) * 400.0).clamp(100.0, 500.0)
      : 100.0;

    if (!mounted) return;
    setState(() {
      _score = lgs.toStringAsFixed(2);
      _rank = ExamDataProvider.estimateRanking(widget.examId, lgs);
      _busy = false;
    });
    _resCtrl.forward(from: 0);
    await _saveHistory();
    await _checkBadges(lgs);
    _showMotivation();
  }

  void _calcKpss() async {
    if (!mounted) return;
    setState(() { _busy = true; _netMap.clear(); });

    if (widget.examId == 'dhbt') {
      double total = 0;
      bool err = false;
      for (final sec in _sections) {
        final title = sec['title'] as String;
        final net = _getNet(title);
        if (net.isNaN) { err = true; continue; }
        _netMap[title] = net;
        total += net;
      }
      if (err) {
        _showError('Soru sınırını aştınız!');
        if (mounted) setState(() => _busy = false);
        return;
      }
      final dhbt = (20.0 + (total * 2.0)).clamp(0.0, 100.0);
      if (!mounted) return;
      setState(() { _score = dhbt.toStringAsFixed(2); _busy = false; });
      _resCtrl.forward(from: 0);
      await _saveHistory();
      return;
    }

    double asp = 0;
    bool err = false;
    for (final sec in _sections) {
      final title = sec['title'] as String;
      final weight = (sec['weight'] as num).toDouble();
      final mean   = (sec['mean'] as num).toDouble();
      final sd     = (sec['sd'] as num).toDouble();
      final net = _getNet(title);
      if (net.isNaN) { err = true; continue; }
      _netMap[title] = net;
      final sp = 50.0 + 10.0 * ((net - mean) / (sd > 0 ? sd : 1.0));
      asp += sp * weight;
    }

    if (err) {
      _showError('Soru sınırını aştınız!');
      if (mounted) setState(() => _busy = false);
      return;
    }

    final finalScore = (70.0 + (30.0 * (2.0 * (asp - 50.0) - 10.0)) / (2.0 * (100.0 - 50.0) - 10.0))
      .clamp(0.0, 100.0);

    if (!mounted) return;
    setState(() {
      _score = finalScore.toStringAsFixed(2);
      _rank = ExamDataProvider.estimateRanking(widget.examId, finalScore);
      _busy = false;
    });
    _resCtrl.forward(from: 0);
    await _saveHistory();
    await _checkBadges(finalScore);
    _showMotivation();
  }

  Future<void> _checkBadges(double s) async {
    final p = await PrefsCache.get();
    final ids = List<String>.from(p.getStringList('earned_badges') ?? []);
    if (!ids.contains('first_calc')) widget.onXPAward(20, badgeId: 'first_calc');
    if (s >= 500 && !ids.contains('score_500'))      widget.onXPAward(200, badgeId: 'score_500');
    else if (s >= 450 && !ids.contains('score_450')) widget.onXPAward(100, badgeId: 'score_450');
    else if (s >= 400 && !ids.contains('score_400')) widget.onXPAward(50,  badgeId: 'score_400');
    else widget.onXPAward(10);
  }

  Future<void> _saveHistory() async {
    final p = await PrefsCache.get();
    final hist = List<String>.from(p.getStringList('history') ?? []);
    hist.insert(0, jsonEncode({
      'date': DateTime.now().toIso8601String(),
      'examTitle': widget.examTitle,
      'examId': widget.examId,
      'score': _score,
      'nets': _netMap.map((k, v) => MapEntry(k, v.toString())),
    }));
    if (hist.length > 150) hist.removeLast();
    await p.setStringList('history', hist);
  }

  void _showError(String msg) {
    if (!mounted) return;
    ScaffoldMessenger.of(context).showSnackBar(SnackBar(
      content: Text(msg),
      backgroundColor: kDanger,
      behavior: SnackBarBehavior.floating,
      shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(12)),
    ));
  }

  void _showMotivation() {
    if (!mounted) return;
    final s = double.tryParse(_score) ?? 0;
    String msg;
    if (_isYks || _isLgs) {
      if (s >= 475)      msg = '🏆 Muhteşem! En iyi üniversitelere ulaşabilirsin!';
      else if (s >= 400) msg = '🎉 Harika puan! Hedeflerine çok yakınsın!';
      else if (s >= 300) msg = '📚 İyi! Biraz daha çalışmaya devam et!';
      else               msg = '💪 Vazgeçme! Her gün ilerliyorsun!';
    } else {
      if (s >= 90)       msg = '🏆 Mükemmel KPSS puanı!';
      else if (s >= 75)  msg = '🎉 Çok iyi! Atama şansın yüksek!';
      else               msg = '📚 Daha fazla çalışmaya devam et!';
    }
    ScaffoldMessenger.of(context).showSnackBar(SnackBar(
      content: Text(msg, style: const TextStyle(fontWeight: FontWeight.bold)),
      backgroundColor: kPrimary,
      duration: const Duration(seconds: 3),
      behavior: SnackBarBehavior.floating,
      shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(12)),
    ));
  }

  void _reset() {
    for (final c in _c.values) c.clear();
    for (final c in _w.values) c.clear();
    _obpCtrl.clear(); _tytCtrl.clear(); _hedefCtrl.clear();
    if (!mounted) return;
    setState(() {
      _score = _rawScore = _obpScore = _aytScore = '0.00';
      _netMap.clear(); _rank = '';
    });
    _resCtrl.reset();
  }

