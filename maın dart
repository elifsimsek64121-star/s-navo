                    subtitle: '$_weakSec – Ort: ${_minNet.toStringAsFixed(1)} net',
                    isDark: isDark,
                  ),
                  const SizedBox(height: 10),
                ],
                if (_bestSec != null) ...[
                  _infoBox(
