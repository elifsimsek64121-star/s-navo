class ExamScreen extends StatefulWidget {
  final String examId, examTitle;
  final bool isPremium;
  final Function(int, {String? badgeId}) onXPAward;
  const ExamScreen({super.key, required this.examId, required this.examTitle, required this.isPremium, required this.onXPAward});
  @override State<ExamScreen> createState() => _ExamScreenState();
}

class _ExamScreenState extends State<ExamScreen> with SingleTickerProviderStateMixin {
  final Map<String, TextEditingController> _c = {}, _w = {};
  final _obpCtrl = TextEditingController();
  final _tytCtrl = TextEditingController();
  final _hedefCtrl = TextEditingController();

  String score = '0.00', rawScore = '0.00', obpScore = '0.00', aytScore = '0.00';
  bool _busy = false;
  late List<Map<String, dynamic>> sections;
  final Map<String, double> netMap = {};
  String _rank = '';

  late final AnimationController _resCtrl;
  late final Animation<double> _resScale;

  bool get isYks => widget.examId.startsWith('yks');
  bool get isLgs => widget.examId == 'lgs';

  @override
  void initState() {
    super.initState();
    _resCtrl = AnimationController(vsync: this, duration: const Duration(milliseconds: 600));
    _resScale = Tween(begin: 0.8, end: 1.0).animate(CurvedAnimation(parent: _resCtrl, curve: Curves.elasticOut));
    final data = ExamDataProvider.getSections(widget.examId);
    sections = List<Map<String, dynamic>>.from(data['all_sections'] as List);
    for (var s in sections) {
      final t = s['title'] as String;
      _c[t] = TextEditingController()..addListener(() => _updateNet(t));
      _w[t] = TextEditingController()..addListener(() => _updateNet(t));
    }
  }

  void _updateNet(String title) {
    final sec = sections.firstWhere((s) => s['title'] == title, orElse: () => {});
    if (sec.isEmpty) return;
    final maxQ = sec['questions'] as int;
    final c = double.tryParse(_c[title]?.text ?? '') ?? 0;
    final w = double.tryParse(_w[title]?.text ?? '') ?? 0;
    if (c >= 0 && w >= 0 && (c + w) <= maxQ) {
      if (mounted) setState(() => netMap[title] = c - (w / 4.0));
    }
  }

  @override
  void dispose() {
    for (var c in _c.values) c.dispose();
    for (var c in _w.values) c.dispose();
    _obpCtrl.dispose(); _tytCtrl.dispose(); _hedefCtrl.dispose(); _resCtrl.dispose();
    super.dispose();
  }

  void calculate() {
    if (isYks) _calcYks();
    else if (isLgs) _calcLgs();
    else _calcKpss();
  }

  void _calcYks() async {
    if (mounted) setState(() => _busy = true);
    double tyt = 0, ayt = 0; bool err = false; netMap.clear();
    for (var sec in sections) {
      final title = sec['title'] as String;
      final tK = ((sec['tyt_katsayi'] ?? 0) as num).toDouble();
      final aK = ((sec['ayt_katsayi'] ?? 0) as num).toDouble();
      final maxQ = sec['questions'] as int;
      final c = double.tryParse(_c[title]?.text ?? '') ?? 0;
      final w = double.tryParse(_w[title]?.text ?? '') ?? 0;
      if (c < 0 || w < 0 || (c + w) > maxQ) { err = true; continue; }
      final net = c - (w / 4.0);
      netMap[title] = net;
      if (tK > 0) tyt += net * tK;
      if (aK > 0 && widget.examId != 'yks_tyt') ayt += net * aK;
    }
    if (err) { _err('Doğru + Yanlış toplam soru sayısını aşamaz!'); if (mounted) setState(() => _busy = false); return; }
    final userTyt = double.tryParse(_tytCtrl.text) ?? 0;
    final tytP = (userTyt > 0 && widget.examId != 'yks_tyt') ? userTyt : 100.0 + tyt;
    final obpRaw = double.tryParse(_obpCtrl.text) ?? 0;
    final obp = (obpRaw * 0.6).clamp(30.0, 60.0);
    final finalScore = (tytP + ayt + obp).clamp(100.0, 560.0);
    if (mounted) setState(() {
      rawScore = (tytP + ayt).toStringAsFixed(2);
      obpScore = obp.toStringAsFixed(2);
      aytScore = ayt.toStringAsFixed(2);
      score = finalScore.toStringAsFixed(2);
      _rank = ExamDataProvider.estimateRanking(widget.examId, finalScore);
      _busy = false;
    });
    _resCtrl.forward(from: 0);
    await _save(); await _checkBadges(finalScore); _snack();
  }

  void _calcLgs() async {
    if (mounted) setState(() => _busy = true);
    double wNet = 0, wTotal = 0; bool err = false; netMap.clear();
    for (var sec in sections) {
      final title = sec['title'] as String;
      final maxQ = sec['questions'] as int;
      final weight = ((sec['weight'] ?? 1.0) as num).toDouble();
      final c = double.tryParse(_c[title]?.text ?? '') ?? 0;
      final w = double.tryParse(_w[title]?.text ?? '') ?? 0;
      if (c < 0 || w < 0 || (c + w) > maxQ) { err = true; continue; }
      final net = c - (w / 4.0);
      netMap[title] = net;
      wNet += net * weight; wTotal += maxQ * weight;
    }
    if (err) { _err('Soru sınırını aştınız!'); if (mounted) setState(() => _busy = false); return; }
    final lgs = wTotal > 0 ? (100.0 + (wNet / wTotal) * 400.0).clamp(100.0, 500.0) : 100.0;
    if (mounted) setState(() { score = lgs.toStringAsFixed(2); _rank = ExamDataProvider.estimateRanking(widget.examId, lgs); _busy = false; });
    _resCtrl.forward(from: 0);
    await _save(); await _checkBadges(lgs); _snack();
  }

  void _calcKpss() async {
    if (mounted) setState(() => _busy = true);
    if (widget.examId == 'dhbt') {
      double total = 0; bool err = false;
      for (var sec in sections) {
        final title = sec['title'] as String;
        final maxQ = sec['questions'] as int;
        final c = double.tryParse(_c[title]?.text ?? '') ?? 0;
        final w = double.tryParse(_w[title]?.text ?? '') ?? 0;
        if (c < 0 || w < 0 || (c + w) > maxQ) { err = true; continue; }
        final net = c - (w / 4.0); total += net; netMap[title] = net;
      }
      if (err) { _err('Soru sınırını aştınız!'); if (mounted) setState(() => _busy = false); return; }
      final dhbt = (20.0 + (total * 2.0)).clamp(0.0, 100.0);
      if (mounted) setState(() { score = dhbt.toStringAsFixed(2); _busy = false; });
      _resCtrl.forward(from: 0); await _save(); return;
    }
    double asp = 0; bool err = false; netMap.clear();
    for (var sec in sections) {
      final title = sec['title'] as String;
      final weight = ((sec['weight'] ?? 0.0) as num).toDouble();
      final maxQ = sec['questions'] as int;
      final mean = ((sec['mean'] ?? 15.0) as num).toDouble();
      final sd = ((sec['sd'] ?? 8.0) as num).toDouble();
      final c = double.tryParse(_c[title]?.text ?? '') ?? 0;
      final w = double.tryParse(_w[title]?.text ?? '') ?? 0;
      if (c < 0 || w < 0 || (c + w) > maxQ) { err = true; continue; }
      final net = c - (w / 4.0); netMap[title] = net;
      final sp = 50.0 + 10.0 * ((net - mean) / (sd > 0 ? sd : 1.0));
      asp += sp * weight;
    }
    if (err) { _err('Soru sınırını aştınız!'); if (mounted) setState(() => _busy = false); return; }
    final finalScore = (70.0 + (30.0 * (2.0 * (asp - 50.0) - 10.0)) / (2.0 * (100.0 - 50.0) - 10.0)).clamp(0.0, 100.0);
    if (mounted) setState(() { score = finalScore.toStringAsFixed(2); _rank = ExamDataProvider.estimateRanking(widget.examId, finalScore); _busy = false; });
    _resCtrl.forward(from: 0);
    await _save(); await _checkBadges(finalScore); _snack();
  }

  Future<void> _checkBadges(double s) async {
    final p = await PrefsCache.get();
    final ids = p.getStringList('earned_badges') ?? [];
    if (!ids.contains('first_calc')) widget.onXPAward(20, badgeId: 'first_calc');
    if (s >= 500 && !ids.contains('score_500')) widget.onXPAward(200, badgeId: 'score_500');
    else if (s >= 450 && !ids.contains('score_450')) widget.onXPAward(100, badgeId: 'score_450');
    else if (s >= 400 && !ids.contains('score_400')) widget.onXPAward(50, badgeId: 'score_400');
    else widget.onXPAward(10);
  }

  Future<void> _save() async {
    final p = await PrefsCache.get();
    final hist = p.getStringList('history') ?? [];
    hist.insert(0, jsonEncode({
      'date': DateTime.now().toIso8601String(),
      'examTitle': widget.examTitle,
      'examId': widget.examId,
      'score': score,
      'nets': netMap.map((k, v) => MapEntry(k, v.toString())),
    }));
    if (hist.length > 150) hist.removeLast();
    await p.setStringList('history', hist);
  }

  void _err(String msg) {
    if (!mounted) return;
    ScaffoldMessenger.of(context).showSnackBar(
      SnackBar(content: Text(msg), backgroundColor: kErrorRed,
        behavior: SnackBarBehavior.floating, shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(12))));
  }

  void _snack() {
    if (!mounted) return;
    final s = double.tryParse(score) ?? 0;
    String msg;
    if (isYks || isLgs) {
      if (s >= 475) msg = '🏆 Muhteşem! En iyi üniversitelere ulaşabilirsin!';
      else if (s >= 400) msg = '🎉 Harika puan! Hedeflerine çok yakınsın!';
      else if (s >= 300) msg = '📚 İyi! Biraz daha çalışmaya devam et!';
      else msg = '💪 Vazgeçme! Her gün biraz daha ilerliyorsun!';
    } else {
      if (s >= 90) msg = '🏆 Mükemmel KPSS puanı! Atama garantiye aldın!';
      else if (s >= 75) msg = '🎉 Çok iyi! Atama şansın yüksek!';
      else msg = '📚 Daha fazla çalışmaya devam et!';
    }
    ScaffoldMessenger.of(context).showSnackBar(SnackBar(
      content: Text(msg, style: const TextStyle(fontWeight: FontWeight.bold)),
      backgroundColor: kPrimaryBlue, duration: const Duration(seconds: 3),
      behavior: SnackBarBehavior.floating, shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(14))));
  }

  void _reset() {
    for (var c in _c.values) c.clear();
    for (var c in _w.values) c.clear();
    _obpCtrl.clear(); _tytCtrl.clear(); _hedefCtrl.clear();
    if (mounted) setState(() { score = rawScore = obpScore = aytScore = '0.00'; netMap.clear(); _rank = ''; });
    _resCtrl.reset();
  }

  void _share() => Share.share(
    '🎯 ${widget.examTitle}\n✅ Puanım: $score\n📊 Tahmin: $_rank\n📱 Sınav365 ile hesapladım!\nhttps://play.google.com/store/apps/details?id=com.sinav365.app',
    subject: 'Sınav365 Puan Sonucum');

  @override
  Widget build(BuildContext context) {
