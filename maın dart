  void calculateYksScore() async {
    setState(() => isCalculating = true);
    double totalTyt = 0.0, totalAyt = 0.0;
    bool hasError = false;
    netMap.clear();

    for (var sec in sections) {
      final title = sec['title'] as String;
      final tytK = (sec['tyt_katsayi'] ?? 0.0) as double;
      final aytK = (sec['ayt_katsayi'] ?? 0.0) as double;
      final maxQ = (sec['questions'] ?? 0) as int;

      final c = double.tryParse(correctControllers[title]?.text ?? '0') ?? 0;
      final w = double.tryParse(wrongControllers[title]?.text ?? '0') ?? 0;

      if (c < 0 || w < 0 || (c + w) > maxQ) {
        hasError = true;
        continue;
      }

      final net = c - (w / 4.0);
      netMap[title] = net;

      if (tytK > 0) totalTyt += net * tytK;
      if (aytK > 0 && widget.examId != 'yks_tyt') totalAyt += net * aytK;
    }

    if (hasError) {
      ScaffoldMessenger.of(context).showSnackBar(
        const SnackBar(content: Text('Doğru + Yanlış, toplam soru sayısını aşamaz!'), backgroundColor: Colors.red),
      );
      setState(() => isCalculating = false);
      return;
    }

    final userTytHam = double.tryParse(tytScoreController.text) ?? 0;
    final tytPuan = (userTytHam > 0 && widget.examId != 'yks_tyt') ? userTytHam : 100.0 + totalTyt;

    final aytPuan = widget.examId == 'yks_tyt' ? 0.0 : totalAyt;

    final diploma = double.tryParse(obpController.text) ?? 0;
    final obp = (diploma * 0.6).clamp(30.0, 60.0);

    final finalScore = tytPuan + aytPuan + obp;

    setState(() {
      rawScore = (tytPuan + aytPuan).toStringAsFixed(2);
      obpScore = obp.toStringAsFixed(2);
      totalAYTScore = aytPuan.toStringAsFixed(2);
      score = finalScore.clamp(100.0, 560.0).toStringAsFixed(2);
      isCalculating = false;
    });

    final prefs = await SharedPreferences.getInstance();
    await prefs.setString('last_${widget.examId}', score);

    final history = prefs.getStringList('history') ?? [];
    history.insert(0, '${DateTime.now().toIso8601String()}|${widget.examTitle}|$score');
    if (history.length > 50) history.removeLast();
    await prefs.setStringList('history', history);
  }

  void calculateKpssScore() async {
    setState(() => isCalculating = true);

    if (widget.examId == 'dhbt') {
      double totalNet = 0.0;
      bool hasError = false;

      for (var sec in sections) {
        final title = sec['title'] as String;
        final maxQ = sec['questions'] as int;

        final c = double.tryParse(correctControllers[title]?.text ?? '0') ?? 0;
        final w = double.tryParse(wrongControllers[title]?.text ?? '0') ?? 0;

        if (c < 0 || w < 0 || (c + w) > maxQ) {
          hasError = true;
          continue;
        }

        final net = c - (w / 4.0);
        totalNet += net;
        netMap[title] = net;
      }

      if (hasError) {
        ScaffoldMessenger.of(context).showSnackBar(const SnackBar(content: Text('Soru sınırını aştınız!'), backgroundColor: Colors.red));
        setState(() => isCalculating = false);
        return;
      }

      final double dhbtScore = 20.0 + (totalNet * 2.0);

      setState(() {
        score = dhbtScore.clamp(0.0, 100.0).toStringAsFixed(2);
        totalAYTScore = totalNet.toStringAsFixed(2);
        isCalculating = false;
      });

      final prefs = await SharedPreferences.getInstance();
      await prefs.setString('last_${widget.examId}', score);
      final history = prefs.getStringList('history') ?? [];
      history.insert(0, '${DateTime.now().toIso8601String()}|${widget.examTitle}|$score');
      if (history.length > 50) history.removeLast();
      await prefs.setStringList('history', history);
      return;
    }

    double totalASP = 0.0;
    bool hasError = false;
    netMap.clear();

    for (var sec in sections) {
      final title = sec['title'] as String;
      final weight = (sec['weight'] ?? 0.0) as double;
      final maxQ = (sec['questions'] ?? 0) as int;
      final mean = (sec['mean'] ?? 15.0) as double;
      final sd = (sec['sd'] ?? 8.0) as double;

      final c = double.tryParse(correctControllers[title]?.text ?? '0') ?? 0;
      final w = double.tryParse(wrongControllers[title]?.text ?? '0') ?? 0;

      if (c < 0 || w < 0 || (c + w) > maxQ) {
        hasError = true;
        continue;
      }

      final net = c - (w / 4.0);
      netMap[title] = net;

      final sp = 50.0 + 10.0 * ((net - mean) / sd);
      totalASP += sp * weight;
    }

    if (hasError) {
      ScaffoldMessenger.of(context).showSnackBar(
        const SnackBar(content: Text('Soru sınırını aştınız!'), backgroundColor: Colors.red),
      );
      setState(() => isCalculating = false);
      return;
    }

    final double finalScore = 70.0 + (30.0 * (2.0 * (totalASP - 50.0) - 10.0)) / (2.0 * (100.0 - 50.0) - 10.0);

    setState(() {
      score = finalScore.clamp(0.0, 100.0).toStringAsFixed(2);
      totalAYTScore = totalASP.toStringAsFixed(4);
      isCalculating = false;
    });

    final prefs = await SharedPreferences.getInstance();
    await prefs.setString('last_${widget.examId}', score);
    final history = prefs.getStringList('history') ?? [];
    history.insert(0, '${DateTime.now().toIso8601String()}|${widget.examTitle}|$score');
    if (history.length > 50) history.removeLast();
    await prefs.setStringList('history', history);
  }

  void _resetInputs() {
    setState(() {
      for (var c in correctControllers.values) c.clear();
      for (var w in wrongControllers.values) w.clear();
      obpController.clear();
      tytScoreController.clear();
      hedefController.clear();
      score = rawScore = obpScore = totalAYTScore = '0.00';
      netMap.clear();
    });
  }

