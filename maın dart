// ─────────────────────────────────────────────────────────────
class SplashScreen extends StatefulWidget {
  final bool isPremium;
  final Function(bool) onThemeToggle, onPremiumChange;
  const SplashScreen({super.key, required this.isPremium, required this.onThemeToggle, required this.onPremiumChange});
  @override State<SplashScreen> createState() => _SplashScreenState();
}

class _SplashScreenState extends State<SplashScreen> with TickerProviderStateMixin {
  late final AnimationController _ctrl;
  late final Animation<double> _scale, _opacity;

  @override
  void initState() {
    super.initState();
    _ctrl = AnimationController(vsync: this, duration: const Duration(milliseconds: 600));
    _scale   = Tween(begin: 0.5, end: 1.0).animate(CurvedAnimation(parent: _ctrl, curve: Curves.easeOutBack));
    _opacity = Tween(begin: 0.0, end: 1.0).animate(CurvedAnimation(parent: _ctrl, curve: Curves.easeIn));
    _animate();
  }

  void _animate() async {
    _ctrl.forward();
    // 400ms bekleme - yeterince gösterir ama hızlı geçer
    await Future.delayed(const Duration(milliseconds: 400));
    if (!mounted) return;
    Navigator.of(context).pushReplacement(PageRouteBuilder(
      pageBuilder: (_, __, ___) => HomeScreen(
        isPremium: widget.isPremium,
        onThemeToggle: widget.onThemeToggle,
        onPremiumChange: widget.onPremiumChange,
      ),
      transitionsBuilder: (_, a, __, c) => FadeTransition(opacity: a, child: c),
      transitionDuration: const Duration(milliseconds: 300),
    ));
  }

  @override
  void dispose() { _ctrl.dispose(); super.dispose(); }

  @override
  Widget build(BuildContext context) => Scaffold(
    body: Container(
      decoration: const BoxDecoration(gradient: LinearGradient(
        colors: [Color(0xFF001529), Color(0xFF0D47A1), Color(0xFF001529)],
        begin: Alignment.topLeft, end: Alignment.bottomRight,
      )),
      child: Center(child: Column(mainAxisAlignment: MainAxisAlignment.center, children: [
        ScaleTransition(scale: _scale,
          child: FadeTransition(opacity: _opacity,
            child: Container(width: 110, height: 110,
              decoration: BoxDecoration(
                gradient: const LinearGradient(colors: [kAccentOrange, Color(0xFFFF3D00)]),
                borderRadius: BorderRadius.circular(32),
                boxShadow: [BoxShadow(color: kAccentOrange.withOpacity(0.5), blurRadius: 30, spreadRadius: 5)],
              ),
              child: const Icon(Icons.track_changes_rounded, color: Colors.white, size: 60),
            ),
          ),
        ),
        const SizedBox(height: 24),
        FadeTransition(opacity: _opacity,
          child: Column(children: [
            Text('Sınav365', style: GoogleFonts.poppins(
              fontSize: 40, fontWeight: FontWeight.w900, color: Colors.white, letterSpacing: 2)),
            const SizedBox(height: 6),
            Container(
              padding: const EdgeInsets.symmetric(horizontal: 16, vertical: 4),
              decoration: BoxDecoration(
                gradient: const LinearGradient(colors: [kAccentOrange, kGold]),
                borderRadius: BorderRadius.circular(20)),
              child: Text('NET & PUAN TAKİP', style: GoogleFonts.poppins(
                fontSize: 12, fontWeight: FontWeight.bold, color: Colors.white, letterSpacing: 3)),
            ),
          ]),
        ),
      ])),
    ),
  );
}

