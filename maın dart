  Future<void> _loadFavorites() async {
    final prefs = await SharedPreferences.getInstance();
    setState(() {
      favorites = (prefs.getStringList('favorites') ?? []).toSet();
    });
  }

  Future<void> _toggleFavorite(String examId) async {
    final prefs = await SharedPreferences.getInstance();
    final newFavs = favorites.toSet();
    if (newFavs.contains(examId)) {
      newFavs.remove(examId);
    } else {
      newFavs.add(examId);
    }
    await prefs.setStringList('favorites', newFavs.toList());
    setState(() => favorites = newFavs);
  }

  void _loadInterstitialAd() {
    InterstitialAd.load(
      adUnitId: 'ca-app-pub-6551908952762916/9670808516',
      request: const AdRequest(),
      adLoadCallback: InterstitialAdLoadCallback(
        onAdLoaded: (ad) {
          _interstitialAd = ad;
          setState(() => _isAdLoaded = true);
        },
        onAdFailedToLoad: (error) {
          setState(() => _isAdLoaded = false);
          Future.delayed(const Duration(seconds: 20), _loadInterstitialAd);
        },
      ),
    );
  }

  void _showInterstitialAd(BuildContext context, String examId, String examTitle) {
    _clickCounter++;

    void navigate() {
      Navigator.of(context).push(PageRouteBuilder(
        pageBuilder: (_, __, ___) => ExamScreen(examId: examId, examTitle: examTitle),
        transitionsBuilder: (_, a, __, c) => FadeTransition(opacity: a, child: c),
        transitionDuration: const Duration(milliseconds: 300),
      ));
    }

    if (_clickCounter <= _skipFirstClicks) {
      navigate();
      return;
    }

    if (_clickCounter >= _adThreshold) {
      _clickCounter = 0;
      if (_isAdLoaded && _interstitialAd != null) {
        _interstitialAd!.fullScreenContentCallback = FullScreenContentCallback(
          onAdDismissedFullScreenContent: (ad) {
            ad.dispose();
            _loadInterstitialAd();
            navigate();
          },
          onAdFailedToShowFullScreenContent: (ad, _) {
            ad.dispose();
            _loadInterstitialAd();
            navigate();
          },
        );
        _interstitialAd!.show();
      } else {
        navigate();
        _loadInterstitialAd();
      }
    } else {
      navigate();
    }
  }

