        backgroundColor: isDark ? kCard : kPrimary,
        foregroundColor: Colors.white,
        elevation: 0,
      ),
      body: SingleChildScrollView(
        padding: const EdgeInsets.all(16),
        child: Column(children: [
          // Giriş kartı
          Container(
            padding: const EdgeInsets.all(16),
            decoration: BoxDecoration(
              color: isDark ? kCard : Colors.white,
              borderRadius: BorderRadius.circular(14),
              border: Border.all(color: isDark ? kBorder : const Color(0xFFE1E4E8)),
            ),
            child: Column(crossAxisAlignment: CrossAxisAlignment.start, children: [
              Text('Hedef Ekle',
                style: _ts(size: 16, w: FontWeight.w800, color: isDark ? Colors.white : Colors.black87)),
              const SizedBox(height: 14),
              TextField(controller: _adCtrl,
                decoration: const InputDecoration(labelText: 'Üniversite Adı',
                  prefixIcon: Icon(Icons.account_balance_rounded, color: kPrimary, size: 20))),
              const SizedBox(height: 10),
              TextField(controller: _bolumCtrl,
                decoration: const InputDecoration(labelText: 'Bölüm',
                  prefixIcon: Icon(Icons.menu_book_rounded, color: kPrimary, size: 20))),
              const SizedBox(height: 10),
              TextField(controller: _puanCtrl,
