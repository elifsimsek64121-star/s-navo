  Future<void> _loadData() async {
    final p = await PrefsCache.get();
    final now = DateTime.now();
    final today = '${now.year}-${now.month.toString().padLeft(2, '0')}-${now.day.toString().padLeft(2, '0')}';
    final lastStr = p.getString('last_open_date');
    int streak = p.getInt('streak') ?? 0;

    if (lastStr != null && lastStr != today) {
      try {
        final last = DateTime.parse(lastStr);
        final diff = now.difference(last).inDays;
        if (diff == 1) streak++;
        else if (diff > 1) streak = 1;
      } catch (_) { streak = 1; }
    } else if (lastStr == null) { streak = 1; }

    if (lastStr != today) await p.setString('last_open_date', today);
    await p.setInt('streak', streak);

    int xp = p.getInt('xp_points') ?? 0;
    final earnedIds = List<String>.from(p.getStringList('earned_badges') ?? []);
    bool changed = false;
    if (streak >= 3  && !earnedIds.contains('streak_3'))  { earnedIds.add('streak_3');  xp += 50;  changed = true; }
    if (streak >= 7  && !earnedIds.contains('streak_7'))  { earnedIds.add('streak_7');  xp += 100; changed = true; }
    if (streak >= 30 && !earnedIds.contains('streak_30')) { earnedIds.add('streak_30'); xp += 300; changed = true; }
    if (changed) {
      await p.setStringList('earned_badges', earnedIds);
      await p.setInt('xp_points', xp);
    }

    if (!mounted) return;
    setState(() {
      _streak = streak;
      _xp = xp;
      _level = (xp ~/ 100) + 1;
      _favs = (p.getStringList('favorites') ?? []).toSet();
      _badges = _allBadges.where((b) => earnedIds.contains(b.id)).toList();
    });
  }

  Future<void> _awardXP(int amount, {String? badgeId}) async {
    final p = await PrefsCache.get();
    final xp = (p.getInt('xp_points') ?? 0) + amount;
    await p.setInt('xp_points', xp);
    if (badgeId != null) {
      final ids = List<String>.from(p.getStringList('earned_badges') ?? []);
      if (!ids.contains(badgeId)) {
        ids.add(badgeId);
        await p.setStringList('earned_badges', ids);
      }
    }
    if (!mounted) return;
    setState(() { _xp = xp; _level = (xp ~/ 100) + 1; });
  }

  Future<void> _toggleFav(String id) async {
    final p = await PrefsCache.get();
    final newFavs = _favs.toSet();
    newFavs.contains(id) ? newFavs.remove(id) : newFavs.add(id);
    await p.setStringList('favorites', newFavs.toList());
    if (!mounted) return;
