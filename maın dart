// PREMIUM MANAGER  ← PRODUCTION: Gerçek Google Play IAP
// ─────────────────────────────────────────────────────────────
class PremiumManager {
  static final _iap = InAppPurchase.instance;
  static StreamSubscription<List<PurchaseDetails>>? _sub;
  static Function(bool)? _onPremiumChange;

  static Future<void> initialize(Function(bool) onPremiumChange) async {
    _onPremiumChange = onPremiumChange;

    final available = await _iap.isAvailable();
    if (!available) {
      debugPrint('IAP not available on this device');
      return;
    }

    _sub = _iap.purchaseStream.listen(
      _handlePurchases,
      onError: (e) => debugPrint('IAP stream error: $e'),
    );

    // Başlangıçta restore et (önceki satın almaları kontrol)
    await _iap.restorePurchases();
  }

  static Future<void> _handlePurchases(List<PurchaseDetails> purchases) async {
    for (final p in purchases) {
      if (p.productID != kPremiumProductId) continue;

      switch (p.status) {
        case PurchaseStatus.purchased:
        case PurchaseStatus.restored:
          // PRODUCTION: Burada receipt validation yapın (backend'e gönderin)
          final valid = await _validateReceipt(p);
          if (valid) {
            await _savePremium(true);
            _onPremiumChange?.call(true);
          }
          await _iap.completePurchase(p);
          break;
        case PurchaseStatus.pending:
          // Kullanıcıya bekleme göster (ödeme işleniyor)
          debugPrint('Purchase pending: ${p.productID}');
          break;
        case PurchaseStatus.error:
          debugPrint('Purchase error: ${p.error?.message}');
          await _iap.completePurchase(p);
          break;
        case PurchaseStatus.canceled:
          debugPrint('Purchase canceled');
          break;
      }
    }
  }

  /// PRODUCTION: Kendi backend'inizde receipt validation yapın
  /// Backend olmadan: false döndür, sonra manuel doğrula
  static Future<bool> _validateReceipt(PurchaseDetails p) async {
    // TODO: Backend'e gönder ve doğrula
    // Örnek: POST /api/validate-receipt
    // Body: { platform, productId, purchaseToken (Android) veya receiptData (iOS) }
    // Bu mock implementasyon - production'da MUTLAKA gerçek validation yapın
    return p.status == PurchaseStatus.purchased || p.status == PurchaseStatus.restored;
  }

  static Future<void> _savePremium(bool v) async {
    final p = await PrefsCache.get();
    await p.setBool('is_premium', v);
  }

  static Future<ProductDetails?> getProduct() async {
    try {
      final res = await _iap.queryProductDetails({kPremiumProductId});
      if (res.error != null) {
        debugPrint('Product query error: ${res.error!.message}');
      }
      return res.productDetails.isNotEmpty ? res.productDetails.first : null;
    } catch (e) {
      debugPrint('getProduct error: $e');
      return null;
    }
  }

  static Future<PurchaseResult> buy() async {
    try {
      final available = await _iap.isAvailable();
      if (!available) return PurchaseResult.notAvailable;

      final prod = await getProduct();
      if (prod == null) return PurchaseResult.productNotFound;

      final success = await _iap.buyNonConsumable(
        purchaseParam: PurchaseParam(productDetails: prod),
      );
      return success ? PurchaseResult.initiated : PurchaseResult.failed;
    } catch (e) {
      debugPrint('buy error: $e');
      if (e.toString().contains('already_owned')) return PurchaseResult.alreadyOwned;
      return PurchaseResult.failed;
    }
  }

  static Future<void> restore() async {
    try { await _iap.restorePurchases(); } catch (e) { debugPrint('restore error: $e'); }
  }

  static void dispose() => _sub?.cancel();
}

enum PurchaseResult { initiated, failed, notAvailable, productNotFound, alreadyOwned }

