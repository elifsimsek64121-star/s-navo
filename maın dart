class StudyPlanScreen extends StatefulWidget {
  const StudyPlanScreen({super.key});
  @override State<StudyPlanScreen> createState() => _StudyPlanScreenState();
}

class _StudyPlanScreenState extends State<StudyPlanScreen> {
  String _exam = 'TYT';
  int _hours = 6;
  List<Map<String, dynamic>> _plan = [];

  static const _examTypes = ['TYT', 'AYT Sayısal', 'AYT EA', 'AYT Sözel', 'KPSS Lisans', 'LGS'];
  static const _subjects = <String, List<Map<String, dynamic>>>{
    'TYT':         [{'sub': 'Türkçe', 'ratio': 0.30}, {'sub': 'Matematik', 'ratio': 0.30}, {'sub': 'Sosyal', 'ratio': 0.20}, {'sub': 'Fen', 'ratio': 0.20}],
    'AYT Sayısal': [{'sub': 'Matematik', 'ratio': 0.40}, {'sub': 'Fizik', 'ratio': 0.20}, {'sub': 'Kimya', 'ratio': 0.20}, {'sub': 'Biyoloji', 'ratio': 0.20}],
    'AYT EA':      [{'sub': 'Matematik', 'ratio': 0.35}, {'sub': 'Edebiyat', 'ratio': 0.30}, {'sub': 'Tarih', 'ratio': 0.20}, {'sub': 'Coğrafya', 'ratio': 0.15}],
    'AYT Sözel':   [{'sub': 'Edebiyat', 'ratio': 0.35}, {'sub': 'Tarih', 'ratio': 0.25}, {'sub': 'Coğrafya', 'ratio': 0.20}, {'sub': 'Felsefe', 'ratio': 0.20}],
    'KPSS Lisans': [{'sub': 'Türkçe', 'ratio': 0.25}, {'sub': 'Matematik', 'ratio': 0.25}, {'sub': 'Tarih', 'ratio': 0.25}, {'sub': 'Coğrafya', 'ratio': 0.25}],
    'LGS':         [{'sub': 'Türkçe', 'ratio': 0.30}, {'sub': 'Matematik', 'ratio': 0.30}, {'sub': 'Fen', 'ratio': 0.25}, {'sub': 'Sosyal', 'ratio': 0.15}],
  };

  void _generate() {
    final subs = _subjects[_exam] ?? [];
    final plan = <Map<String, dynamic>>[];
    final days = ['Pazartesi', 'Salı', 'Çarşamba', 'Perşembe', 'Cuma', 'Cumartesi', 'Pazar'];
    for (var i = 0; i < 7; i++) {
      final sessions = <Map<String, dynamic>>[];
      if (i == 6) {
        sessions.add({'subject': '📖 Tekrar & Test', 'minutes': _hours * 60});
      } else {
        for (final sub in subs) {
          final mins = (_hours * 60 * (sub['ratio'] as double)).round();
          sessions.add({'subject': sub['sub'], 'minutes': mins});
        }
      }
      plan.add({'day': days[i], 'sessions': sessions});
    }
    setState(() => _plan = plan);
  }

  @override
  Widget build(BuildContext context) {
    final isDark = Theme.of(context).brightness == Brightness.dark;
    return Scaffold(
      backgroundColor: isDark ? kSurface : const Color(0xFFF6F8FA),
      appBar: AppBar(
        title: Text('Çalışma Planı', style: _ts(size: 17, w: FontWeight.w700, color: Colors.white)),
        backgroundColor: isDark ? kCard : kPrimary,
        foregroundColor: Colors.white,
        elevation: 0,
      ),
      body: SingleChildScrollView(
        padding: const EdgeInsets.all(16),
        child: Column(crossAxisAlignment: CrossAxisAlignment.start, children: [
          // Ayar kartı
          Container(
            padding: const EdgeInsets.all(16),
            decoration: BoxDecoration(
              color: isDark ? kCard : Colors.white,
              borderRadius: BorderRadius.circular(14),
              border: Border.all(color: isDark ? kBorder : const Color(0xFFE1E4E8)),
            ),
            child: Column(crossAxisAlignment: CrossAxisAlignment.start, children: [
              Text('Plan Oluştur',
                style: _ts(size: 16, w: FontWeight.w800, color: isDark ? Colors.white : Colors.black87)),
              const SizedBox(height: 14),
              DropdownButtonFormField<String>(
                value: _exam,
                items: _examTypes.map((t) => DropdownMenuItem(value: t, child: Text(t))).toList(),
                onChanged: (v) => setState(() => _exam = v!),
                decoration: const InputDecoration(labelText: 'Hedef Sınav',
                  prefixIcon: Icon(Icons.school_rounded, color: kPrimary, size: 20)),
              ),
              const SizedBox(height: 14),
              Text('Günlük Çalışma: $_hours saat',
                style: _ts(size: 13, w: FontWeight.w700,
                  color: isDark ? Colors.white : Colors.black87)),
              Slider(
                value: _hours.toDouble(), min: 2, max: 14, divisions: 12,
                label: '$_hours saat', activeColor: kPrimary,
                onChanged: (v) => setState(() => _hours = v.toInt()),
              ),
              SizedBox(width: double.infinity, child: ElevatedButton.icon(
                onPressed: _generate,
                icon: const Icon(Icons.calendar_month_rounded),
                label: const Text('Haftalık Plan Oluştur'),
              )),
            ]),
          ),

          if (_plan.isNotEmpty) ...[
            const SizedBox(height: 20),
            Text('Haftalık Program',
              style: _ts(size: 16, w: FontWeight.w800, color: isDark ? Colors.white : Colors.black87)),
            const SizedBox(height: 12),
            ..._plan.map((day) => Container(
              margin: const EdgeInsets.only(bottom: 10),
              decoration: BoxDecoration(
                color: isDark ? kCard : Colors.white,
                borderRadius: BorderRadius.circular(14),
                border: Border.all(color: isDark ? kBorder : const Color(0xFFE1E4E8)),
              ),
              child: Column(crossAxisAlignment: CrossAxisAlignment.start, children: [
                Container(
                  padding: const EdgeInsets.symmetric(horizontal: 16, vertical: 12),
                  decoration: BoxDecoration(
                    color: kPrimary.withAlpha(15),
                    borderRadius: const BorderRadius.vertical(top: Radius.circular(14)),
                    border: Border(bottom: BorderSide(
                      color: isDark ? kBorder : const Color(0xFFE1E4E8))),
                  ),
                  child: Row(children: [
                    const Icon(Icons.calendar_today_rounded, color: kPrimary, size: 16),
                    const SizedBox(width: 8),
                    Text(day['day'] as String,
                      style: _ts(size: 15, w: FontWeight.w700, color: kPrimary)),
                    const Spacer(),
                    Text('$_hours saat',
                      style: _ts(size: 12, color: isDark ? Colors.white38 : Colors.black38)),
                  ]),
                ),
                Padding(
                  padding: const EdgeInsets.all(12),
                  child: Wrap(spacing: 8, runSpacing: 6,
                    children: (day['sessions'] as List<Map<String, dynamic>>).map((s) =>
                      Container(
                        padding: const EdgeInsets.symmetric(horizontal: 12, vertical: 7),
                        decoration: BoxDecoration(
                          color: kPrimary.withAlpha(15),
                          borderRadius: BorderRadius.circular(10),
                          border: Border.all(color: kPrimary.withAlpha(40)),
                        ),
                        child: Text('${s['subject']}: ${s['minutes']} dk',
                          style: _ts(size: 13, w: FontWeight.w600, color: kPrimary)),
                      )
                    ).toList(),
                  ),
                ),
              ]),
            )),
          ],
        ]),
      ),
    );
  }
