  Future<void> _loadData() async {
    if (mounted) setState(() => _loading = true);

    final p = await PrefsCache.get();
    final histRaw = p.getStringList('history') ?? [];
    final tryRaw = p.getStringList('tryouts') ?? [];

    // Paralel parse
    final scores = <double>[];
    for (final h in histRaw) {
      try {
        final decoded = jsonDecode(h) as Map<String, dynamic>;
        final s = double.tryParse(decoded['score']?.toString() ?? '0');
        if (s != null && s > 0) scores.add(s);
      } catch (_) {}
    }

    final tryouts = <TryoutExam>[];
    for (final s in tryRaw) {
      try { tryouts.add(TryoutExam.fromJson(jsonDecode(s))); } catch (_) {}
    }
    tryouts.sort((a, b) => a.date.compareTo(b.date));

    final netAvg = <String, List<double>>{};
    for (final t in tryouts) {
      t.nets.forEach((sec, net) => netAvg.putIfAbsent(sec, () => []).add(net));
    }

    final avg = netAvg.map((k, v) =>
      MapEntry(k, v.isNotEmpty ? v.reduce((a, b) => a + b) / v.length : 0.0));

    String? weakSec; double minNet = double.infinity;
    String? bestSec; double maxNet = double.negativeInfinity;
    avg.forEach((sec, a) {
      if (a < minNet) { minNet = a; weakSec = sec; }
      if (a > maxNet) { maxNet = a; bestSec = sec; }
    });

    if (mounted) setState(() {
      _scores = scores.take(20).toList().reversed.toList();
      _tryouts = tryouts;
      _weakSec = weakSec;
      _minNet = minNet == double.infinity ? 0 : minNet;
      _bestSec = bestSec;
      _maxNet = maxNet == double.negativeInfinity ? 0 : maxNet;
      _loading = false;
    });
  }

