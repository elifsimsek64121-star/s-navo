    setState(() => _loading = true);
    try {
      final prod = await PremiumManager.getProduct();
      if (mounted) {
        setState(() {
          _product = prod;
          _priceStr = prod?.price ?? 'Fiyat alınamadı';
          _loading = false;
        });
      }
    } catch (e) {
      if (mounted) setState(() { _loading = false; _priceStr = 'Bağlantı hatası'; });
    }
  }

  Future<void> _purchase() async {
    if (_product == null) {
      _showStatus('❌ Ürün bulunamadı. Lütfen tekrar deneyin.', isError: true);
      return;
    }

    setState(() { _purchasing = true; _statusMsg = ''; });

    final result = await PremiumManager.buy();

    if (!mounted) return;

    switch (result) {
      case PurchaseResult.initiated:
        _showStatus('⏳ Ödeme işleniyor... Lütfen bekleyin.', isError: false);
        // Satın alma başarılı olduğunda PremiumManager stream'i tetikler
        break;
      case PurchaseResult.alreadyOwned:
        _showStatus('✅ Zaten premium üyesiniz! Restore ediliyor...', isError: false);
        await PremiumManager.restore();
        widget.onPremiumChange(true);
        await Future.delayed(const Duration(seconds: 2));
        if (mounted) Navigator.pop(context);
        break;
      case PurchaseResult.notAvailable:
        _showStatus('❌ Bu cihazda satın alma mevcut değil.', isError: true);
