// AI COACH CARD – Güvenli Claude API (memory leak yok)
// ─────────────────────────────────────────────────────────────
class _AiCoachCard extends StatefulWidget {
  const _AiCoachCard();
  @override State<_AiCoachCard> createState() => _AiCoachCardState();
}

class _AiCoachCardState extends State<_AiCoachCard> {
  String _resp  = '';
  bool _loading = false;
  bool _disposed = false;

  @override
  void dispose() { _disposed = true; super.dispose(); }

  Future<void> _ask() async {
    if (_loading || _disposed) return;
    if (mounted) setState(() { _loading = true; _resp = ''; });

    final p = await PrefsCache.get();
    final hist    = p.getStringList('history')  ?? [];
    final tryouts = p.getStringList('tryouts')  ?? [];
    final streak  = p.getInt('streak') ?? 0;

    // Kullanıcı bağlamı oluştur
    final sb = StringBuffer();
    if (hist.isNotEmpty) {
      try {
        final latest = jsonDecode(hist.first) as Map<String, dynamic>;
        sb.write('Son hesaplama: ${latest['examTitle']} – ${latest['score']} puan. ');
      } catch (_) {}
    }
    if (tryouts.isNotEmpty) {
      try {
        final latest = TryoutExam.fromJson(jsonDecode(tryouts.first) as Map<String, dynamic>);
        if (latest.nets.isNotEmpty) {
          final weak = latest.nets.entries.reduce((a, b) => a.value < b.value ? a : b);
          sb.write('En zayıf ders: ${weak.key} (${weak.value.toStringAsFixed(1)} net). ');
          final best = latest.nets.entries.reduce((a, b) => a.value > b.value ? a : b);
          sb.write('En güçlü ders: ${best.key} (${best.value.toStringAsFixed(1)} net). ');
        }
      } catch (_) {}
    }
    final ctx = sb.isEmpty ? 'Henüz veri yok, genel motivasyon ver.' : sb.toString();

    // API key yoksa fallback
    if (kAnthropicApiKey.isEmpty || kAnthropicApiKey == 'YOUR_ANTHROPIC_API_KEY') {
      _setFallback();
      return;
    }

    http.Client? client;
    try {
      client = http.Client();
      final res = await client.post(
        Uri.parse('https://api.anthropic.com/v1/messages'),
        headers: {
          'Content-Type': 'application/json',
          'x-api-key': kAnthropicApiKey,
          'anthropic-version': '2023-06-01',
        },
        body: jsonEncode({
          'model': kClaudeModel,
          'max_tokens': 700,
          'system':
            'Sen deneyimli bir Türk sınav koçusun. '
            'Öğrencilere motive edici, somut ve kişiselleştirilmiş öneriler verirsin. '
            'Her zaman Türkçe yaz. Samimi, sıcak ve cesaretlendirici ol.',
          'messages': [{
            'role': 'user',
            'content': 'Öğrenci durumu: $ctx\n'
              'Çalışma serisi: $streak gün.\n\n'
              'Bu öğrenciye 5 madde halinde, numaralı liste şeklinde, '
              'kısa ve etkili öneriler ver. '
              'Her madde farklı bir strateji içersin. Emojiler kullan.',
          }],
        }),
      ).timeout(const Duration(seconds: 30));

      if (_disposed) return;

      if (res.statusCode == 200) {
        final data = jsonDecode(utf8.decode(res.bodyBytes)) as Map<String, dynamic>;
        final text = (data['content'] as List)
          .whereType<Map<String, dynamic>>()
          .where((c) => c['type'] == 'text')
          .map((c) => c['text'] as String)
          .join('\n');
        if (!_disposed && mounted) setState(() { _resp = text.trim(); _loading = false; });
      } else {
        debugPrint('Claude API ${res.statusCode}: ${res.body}');
        _setFallback();
      }
    } on TimeoutException {
      debugPrint('Claude API timeout');
      _setFallback();
    } catch (e) {
      debugPrint('Claude API error: $e');
      _setFallback();
    } finally {
      client?.close();
    }
  }

  void _setFallback() {
    if (_disposed) return;
    if (mounted) setState(() {
      _resp =
        '1. 🎯 En zayıf dersine günde en az 2 saat ayır, konu özetleri çıkar!\n'
        '2. 📚 Pomodoro: 25 dk çalış, 5 dk mola – 4 turdan sonra 20 dk uzun mola!\n'
        '3. ✍️ Yanlış sorularını özel deftere yaz, her gün tekrar çöz!\n'
        '4. 🔥 Çalışma serini koru! Tutarlılık her şeyden önemlidir!\n'
        '5. 📊 Deneme sonuçlarını analiz et: hangi konulardan hata yaptığını tespit et!';
      _loading = false;
    });
  }

  @override
  Widget build(BuildContext context) {
    final isDark = Theme.of(context).brightness == Brightness.dark;
    return Container(
      padding: const EdgeInsets.all(18),
      decoration: BoxDecoration(
        color: isDark ? kCard : Colors.white,
        borderRadius: BorderRadius.circular(16),
        border: Border.all(color: kPrimary.withAlpha(60)),
      ),
      child: Column(crossAxisAlignment: CrossAxisAlignment.start, children: [
        Row(children: [
          Container(
            padding: const EdgeInsets.all(8),
            decoration: BoxDecoration(
              color: kPrimary.withAlpha(25),
              borderRadius: BorderRadius.circular(10),
            ),
            child: const Icon(Icons.smart_toy_rounded, color: kPrimary, size: 22)),
          const SizedBox(width: 12),
          Expanded(child: Column(crossAxisAlignment: CrossAxisAlignment.start, children: [
            Text('Claude AI Koç',
              style: _ts(size: 16, w: FontWeight.w800, color: isDark ? Colors.white : Colors.black87)),
            Text('Kişisel sınav koçun',
              style: _ts(size: 12, color: isDark ? Colors.white38 : Colors.black38)),
          ])),
          Container(
            padding: const EdgeInsets.symmetric(horizontal: 8, vertical: 3),
            decoration: BoxDecoration(
              color: kSuccess.withAlpha(25),
              borderRadius: BorderRadius.circular(8),
              border: Border.all(color: kSuccess.withAlpha(60)),
            ),
            child: Text('CANLI', style: _ts(size: 10, w: FontWeight.w800, color: kSuccess)),
          ),
        ]),
        if (_resp.isNotEmpty) ...[
          const SizedBox(height: 14),
          Container(
            padding: const EdgeInsets.all(14),
            decoration: BoxDecoration(
              color: isDark ? kCardElevated : const Color(0xFFF6F8FA),
              borderRadius: BorderRadius.circular(12),
            ),
            child: Text(_resp, style: _ts(size: 14, color: isDark ? Colors.white70 : Colors.black87, height: 1.8)),
          ),
        ],
        if (_resp.isEmpty && !_loading)
          Padding(
            padding: const EdgeInsets.only(top: 10),
            child: Text('Verilerinizi analiz edip kişisel öneriler sunacağım!',
              style: _ts(size: 13, color: isDark ? Colors.white38 : Colors.black38)),
          ),
        const SizedBox(height: 14),
        SizedBox(width: double.infinity, child: ElevatedButton.icon(
          onPressed: _loading ? null : _ask,
          icon: _loading
            ? const SizedBox(width: 16, height: 16,
                child: CircularProgressIndicator(color: Colors.white, strokeWidth: 2))
            : const Icon(Icons.auto_awesome_rounded),
          label: Text(_loading ? 'Claude düşünüyor...' : 'Kişisel Öneri Al',
            style: _ts(size: 14, w: FontWeight.w700, color: Colors.white)),
        )),
      ]),
    );
  }
}

