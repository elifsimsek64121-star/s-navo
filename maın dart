class ExamScreen extends StatefulWidget {
  final String examId;
  final String examTitle;

  const ExamScreen({super.key, required this.examId, required this.examTitle});

  @override
  State<ExamScreen> createState() => _ExamScreenState();
}

class _ExamScreenState extends State<ExamScreen> {
  final Map<String, TextEditingController> correctControllers = {};
  final Map<String, TextEditingController> wrongControllers = {};
  final TextEditingController obpController = TextEditingController();
  final TextEditingController tytScoreController = TextEditingController();
  final TextEditingController hedefController = TextEditingController();

  String score = '0.00', rawScore = '0.00', obpScore = '0.00', totalAYTScore = '0.00';
  bool isCalculating = false;
  late List<Map<String, dynamic>> sections;
  final Map<String, double> netMap = {};

  @override
  void initState() {
    super.initState();
    final data = getSections(widget.examId);
    sections = data['all_sections'] as List<Map<String, dynamic>>;
    for (var sec in sections) {
      final title = sec['title'] as String;
      correctControllers[title] = TextEditingController()..addListener(() => _updateNet(title));
      wrongControllers[title] = TextEditingController()..addListener(() => _updateNet(title));
    }
  }

  void _updateNet(String title) {
    final sec = sections.firstWhere((s) => s['title'] == title, orElse: () => <String, dynamic>{});
    if (sec.isEmpty) return;
    final maxQ = (sec['questions'] ?? 0) as int;
    final c = double.tryParse(correctControllers[title]?.text ?? '0') ?? 0;
    final w = double.tryParse(wrongControllers[title]?.text ?? '0') ?? 0;
    if (c >= 0 && w >= 0 && (c + w) <= maxQ) {
      setState(() {
        netMap[title] = c - (w / 4);
      });
    }
  }

  @override
  void dispose() {
    correctControllers.values.forEach((c) => c.dispose());
    wrongControllers.values.forEach((w) => w.dispose());
    obpController.dispose();
    tytScoreController.dispose();
    hedefController.dispose();
    super.dispose();
  }

  bool isYksExam() => widget.examId.startsWith('yks');
  bool isAgsExam() => widget.examId == 'ags_general';

  Map<String, dynamic> getSections(String examId) {
    if (examId.startsWith('yks')) {
      final tyt = [
        {'title': 'TYT Türkçe', 'questions': 40, 'tyt_katsayi': 3.3},
        {'title': 'TYT Sosyal Bilimler', 'questions': 20, 'tyt_katsayi': 3.4},
        {'title': 'TYT Temel Matematik', 'questions': 40, 'tyt_katsayi': 3.3},
        {'title': 'TYT Fen Bilimleri', 'questions': 20, 'tyt_katsayi': 3.4},
      ];
      final ayt = <Map<String, dynamic>>[];

      switch (examId) {
        case 'yks_tyt': break;
        case 'yks_sayisal':
          ayt.addAll([
            {'title': 'AYT Matematik', 'questions': 40, 'ayt_katsayi': 3.0},
            {'title': 'AYT Fizik', 'questions': 14, 'ayt_katsayi': 2.85},
            {'title': 'AYT Kimya', 'questions': 13, 'ayt_katsayi': 3.07},
            {'title': 'AYT Biyoloji', 'questions': 13, 'ayt_katsayi': 3.07},
          ]);
          break;
        case 'yks_esit_agirlik':
          ayt.addAll([
            {'title': 'AYT Matematik', 'questions': 40, 'ayt_katsayi': 3.0},
            {'title': 'AYT Türk Dili ve Edebiyatı', 'questions': 24, 'ayt_katsayi': 3.0},
            {'title': 'AYT Tarih-1', 'questions': 10, 'ayt_katsayi': 2.80},
            {'title': 'AYT Coğrafya-1', 'questions': 6, 'ayt_katsayi': 3.33},
          ]);
          break;
        case 'yks_sozel':
          ayt.addAll([
            {'title': 'AYT Türk Dili ve Edebiyatı', 'questions': 24, 'ayt_katsayi': 3.0},
            {'title': 'AYT Tarih-1', 'questions': 10, 'ayt_katsayi': 2.80},
            {'title': 'AYT Coğrafya-1', 'questions': 6, 'ayt_katsayi': 3.33},
            {'title': 'AYT Tarih-2', 'questions': 11, 'ayt_katsayi': 2.91},
            {'title': 'AYT Coğrafya-2', 'questions': 11, 'ayt_katsayi': 2.91},
            {'title': 'AYT Felsefe Grubu', 'questions': 12, 'ayt_katsayi': 3.0},
            {'title': 'AYT Din Kültürü', 'questions': 6, 'ayt_katsayi': 3.33},
          ]);
          break;
        case 'yks_dil':
          ayt.add({'title': 'YDT Yabancı Dil', 'questions': 80, 'ayt_katsayi': 3.0});
          break;
      }

      final all = [...tyt, ...ayt];
      return {'all_sections': all, 'tyt_sections': tyt, 'ayt_sections': ayt};
    }

    List<Map<String, dynamic>> kpss = [];
    switch (examId) {
      case 'ortaogretim':
        kpss = [
          {'title': 'Genel Yetenek', 'questions': 60, 'weight': 0.5, 'mean': 15.5, 'sd': 8.2},
          {'title': 'Genel Kültür', 'questions': 60, 'weight': 0.5, 'mean': 13.8, 'sd': 7.2},
        ];
        break;
      case 'onlisans':
        kpss = [
          {'title': 'Genel Yetenek', 'questions': 60, 'weight': 0.5, 'mean': 20.5, 'sd': 8.0},
          {'title': 'Genel Kültür', 'questions': 60, 'weight': 0.5, 'mean': 18.2, 'sd': 7.5},
        ];
        break;
      case 'lisans':
        kpss = [
