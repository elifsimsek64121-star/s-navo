}

class _AddTryoutSheetState extends State<AddTryoutSheet> {
  String _type = 'TYT';
  DateTime _date = DateTime.now();
  final _scoreCtrl = TextEditingController();
  final _notesCtrl = TextEditingController();
  final Map<String, TextEditingController> _netCtrl = {};

  static const _types = ['TYT', 'AYT Sayısal', 'AYT EA', 'AYT Sözel', 'KPSS Lisans', 'KPSS Ön Lisans', 'LGS'];
  static const _secMap = {
    'TYT':           ['Türkçe', 'Sosyal', 'Matematik', 'Fen'],
    'AYT Sayısal':   ['Matematik', 'Fizik', 'Kimya', 'Biyoloji'],
    'AYT EA':        ['Matematik', 'Edebiyat', 'Tarih-1', 'Coğrafya-1'],
    'AYT Sözel':     ['Edebiyat', 'Tarih-1', 'Coğrafya-1', 'Tarih-2', 'Coğrafya-2', 'Felsefe', 'Din'],
    'KPSS Lisans':   ['Türkçe', 'Matematik', 'Tarih', 'Coğrafya', 'Vatandaşlık', 'Güncel'],
    'KPSS Ön Lisans':['Genel Yetenek', 'Genel Kültür'],
    'LGS':           ['Türkçe', 'Matematik', 'İnkılap', 'Din', 'Fen', 'Yabancı Dil'],
  };

  List<String> get _secs => _secMap[_type] ?? [];

  @override
  void initState() { super.initState(); _refreshCtrl(); }

  void _refreshCtrl() {
    for (final c in _netCtrl.values) c.dispose();
    _netCtrl.clear();
    for (final s in _secs) _netCtrl[s] = TextEditingController();
  }

  @override
  void dispose() {
    _scoreCtrl.dispose(); _notesCtrl.dispose();
    for (final c in _netCtrl.values) c.dispose();
    super.dispose();
  }

  void _save() {
    final score = double.tryParse(_scoreCtrl.text.trim()) ?? 0;
    final nets = {for (final s in _secs) s: double.tryParse(_netCtrl[s]?.text ?? '') ?? 0.0};
    widget.onSave(TryoutExam(
      id: DateTime.now().millisecondsSinceEpoch.toString(),
      examType: _type, date: _date, nets: nets, score: score,
      notes: _notesCtrl.text.trim().isEmpty ? null : _notesCtrl.text.trim(),
    ));
    Navigator.pop(context);
  }

  @override
  Widget build(BuildContext context) {
    final isDark = Theme.of(context).brightness == Brightness.dark;
    return Container(
      decoration: BoxDecoration(
        color: isDark ? kDarkCard : Colors.white,
        borderRadius: const BorderRadius.vertical(top: Radius.circular(24))),
      child: SafeArea(child: SingleChildScrollView(
        padding: EdgeInsets.only(left: 20, right: 20, top: 20, bottom: MediaQuery.of(context).viewInsets.bottom + 20),
        child: Column(crossAxisAlignment: CrossAxisAlignment.start, children: [
          Center(child: Container(width: 40, height: 4,
            decoration: BoxDecoration(color: Colors.grey.withOpacity(0.3), borderRadius: BorderRadius.circular(2)))),
          const SizedBox(height: 16),
          Text('Deneme Sınavı Ekle', style: GoogleFonts.poppins(fontSize: 20, fontWeight: FontWeight.bold)),
          const SizedBox(height: 16),
          DropdownButtonFormField<String>(value: _type,
            items: _types.map((t) => DropdownMenuItem(value: t, child: Text(t))).toList(),
            onChanged: (v) => setState(() { _type = v!; _refreshCtrl(); }),
            decoration: const InputDecoration(labelText: 'Sınav Türü',
              prefixIcon: Icon(Icons.assignment_rounded, color: kPrimaryBlue))),
          const SizedBox(height: 12),
          GestureDetector(
            onTap: () async {
              final d = await showDatePicker(context: context, initialDate: _date,
                firstDate: DateTime(2020), lastDate: DateTime.now());
              if (d != null && mounted) setState(() => _date = d);
            },
            child: Container(padding: const EdgeInsets.all(14),
              decoration: BoxDecoration(
                border: Border.all(color: Colors.grey.shade400), borderRadius: BorderRadius.circular(14),
                color: isDark ? kDarkInput : Colors.white),
              child: Row(children: [
                const Icon(Icons.calendar_today_rounded, color: kPrimaryBlue, size: 20),
                const SizedBox(width: 12),
                Text('${_date.day}.${_date.month}.${_date.year}', style: const TextStyle(fontSize: 15)),
              ])),
          ),
          const SizedBox(height: 12),
          TextField(controller: _scoreCtrl, keyboardType: const TextInputType.numberWithOptions(decimal: true),
            decoration: const InputDecoration(labelText: 'Toplam Puan',
              prefixIcon: Icon(Icons.star_rounded, color: kGold))),
          const SizedBox(height: 16),
          Text('Ders Netleri:', style: GoogleFonts.poppins(fontWeight: FontWeight.bold, fontSize: 15)),
          const SizedBox(height: 10),
          ..._secs.map((sec) => Padding(padding: const EdgeInsets.only(bottom: 8),
            child: TextField(controller: _netCtrl[sec],
              keyboardType: const TextInputType.numberWithOptions(decimal: true, signed: true),
              decoration: InputDecoration(labelText: '$sec neti',
                contentPadding: const EdgeInsets.symmetric(horizontal: 14, vertical: 12))))),
          const SizedBox(height: 8),
          TextField(controller: _notesCtrl, maxLines: 2,
            decoration: const InputDecoration(labelText: 'Notlar (isteğe bağlı)',
              prefixIcon: Icon(Icons.edit_note_rounded, color: Colors.grey))),
          const SizedBox(height: 20),
          SizedBox(width: double.infinity,
            child: ElevatedButton(onPressed: _save, child: const Text('Kaydet', style: TextStyle(fontSize: 16)))),
        ]),
      )),
    );
  }
